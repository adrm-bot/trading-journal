91:    dup = k.duplicated("open_ts", keep=False)
92:    if dup.any():
93:        # monthly/daily overlap: assert identical rows, then drop
94:        g = k[dup].groupby("open_ts").agg(["min", "max"])
95:        mismatch = 0
96:        for c in ["open", "high", "low", "close", "volume"]:
97:            mismatch += int((g[(c, "min")] != g[(c, "max")]).sum())
98:        assert mismatch == 0, f"{symbol}: {mismatch} conflicting duplicate kline rows"
99:        k = k.drop_duplicates("open_ts", keep="first")
100:    return k.reset_index(drop=True)
