428:def sweep(symbol: str):
429:    df, excluded, _ = load(symbol)
430:    feat, f, b2, b1 = tracks(df)
431:    idx = trim(f).index
432:    exc = full_excluded(excluded, trim(f))
433:    B1 = trim(b1)
434:    base_pooled = None
435:    rows = {}
436:    for dwell in (0, 2, 4, 8):
437:        for confirm in (0, 1, 2, 3):
438:            cp = ClassifierParams(min_dwell=dwell, confirm_bars=confirm)
439:            f2 = classifier.classify(feat, cp)
440:            p2 = pair_stats(B1, trim(f2)["regime"], idx, exc)
441:            leads2 = np.concatenate([p2[c]["leads"] for c in CLASSES])
442:            med = float(np.median(leads2)) if len(leads2) else np.nan
443:            if dwell == 0 and confirm == 0:
444:                base_pooled = med
445:            rows[f"dwell{dwell}_confirm{confirm}"] = {
446:                "median_lead": med, "n": int(len(leads2)),
447:                "lead_sacrificed": round(base_pooled - med, 2) if base_pooled is not None else np.nan,
448:                "churn3_F": round(p2["churn_fused"], 3),
449:                "flap_F": round(p2["flap_fused"], 3),
450:                "false_per_100c": round(sum(p2[c]["false_per_100c"] for c in CLASSES), 3),
451:            }
452:    out = {"symbol": symbol, "grid": rows,
453:           "churn3_B1": round(leadlag.churn3(leadlag.to_super(B1)), 3)}
454:    RESULTS.mkdir(exist_ok=True)
455:    (RESULTS / f"{symbol}_hysteresis.json").write_text(json.dumps(out, indent=1))
456:    return out
