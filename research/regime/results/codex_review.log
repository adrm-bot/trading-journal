39:def _tag(p: Path) -> str:
40:    """Trailing date portion of a Vision zip stem: YYYY-MM (monthly) or YYYY-MM-DD (daily)."""
41:    parts = p.stem.split("-")
42:    if len(parts) >= 3 and parts[-3].isdigit() and len(parts[-3]) == 4:
43:        return "-".join(parts[-3:])
44:    return "-".join(parts[-2:])
