84:def _cls_row(st):
85:    s = leadlag.summarize(st["leads"])
86:    ci = leadlag.month_bootstrap_median(st["leads"], st["months"])
87:    ends = leadlag.summarize(st["end_deltas"])
88:    ratio = st["n_fused"] / st["n_base"] if st["n_base"] else np.nan
89:    return {
90:        "n_base_eps": st["n_base"], "n_fused_eps": st["n_fused"],
91:        "eps_ratio": round(ratio, 3), "ratio_invalid": bool(ratio > 1.5),
92:        "matched_frac": round(st["n_matched"] / st["n_base"], 3) if st["n_base"] else np.nan,
93:        "n_miss": st["n_miss"], "n_false": st["n_false"],
94:        "false_per_100c": round(st["false_per_100c"], 3),
95:        "start_lead": {**s, "ci95_month_boot": ci},
96:        "end_lead": ends,
97:        "excluded": [st["n_excluded_base"], st["n_excluded_fused"]],
98:    }
