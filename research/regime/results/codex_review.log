52:def _read_zip_csv(path: Path, **kw) -> pd.DataFrame:
53:    """Read the single CSV inside a Vision zip, tolerating an optional header row."""
54:    with zipfile.ZipFile(path) as z:
55:        name = z.namelist()[0]
56:        raw = z.read(name)
57:    first = raw.split(b"\n", 1)[0]
58:    has_header = not first.split(b",")[0].strip().replace(b".", b"").replace(b"-", b"").isdigit()
59:    return pd.read_csv(io.BytesIO(raw), header=0 if has_header else None, **kw)
