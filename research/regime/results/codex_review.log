459:def main():
460:    ap = argparse.ArgumentParser()
461:    ap.add_argument("symbol", nargs="?", default="BTCUSDT")
462:    ap.add_argument("--stage", default="headline")
463:    ap.add_argument("--nulls", type=int, default=200)
464:    args = ap.parse_args()
465:    if hasattr(sys.stdout, "reconfigure"):
466:        sys.stdout.reconfigure(encoding="utf-8")
467:    stages = ["headline", "null", "collapse", "sweep", "posthoc"] if args.stage == "all" \
468:        else [args.stage]
469:    for st in stages:
470:        print(f"=== {args.symbol} :: {st} ===", flush=True)
471:        if st == "headline":
472:            out = headline(args.symbol)
