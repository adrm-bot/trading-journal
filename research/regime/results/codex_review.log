1:#!/usr/bin/env python3
2:"""Causal feature layer.
3:
4:Every value at row t uses data from candle closes <= t (the current candle's own close is
5:included by convention — labels are stamped at close time). This is the only module that
6:computes indicators; classifier/baseline consume the returned frame and never touch raw data.
7:
8:Causality rules enforced here:
9:- rolling windows end at the current row (pandas default); никогда center=True
10:- percentile ranks are computed against the STRICTLY-PAST window: from the inclusive rolling
11:  rank r over w obs, past-only pct = (r*w - 1)/(w - 1)  (removes the current value's self-count)
12:- threshold-style quantiles use .shift(1)
13:- recursive filters (EMA/Wilder) run forward from the first row only
14:- dOI is defined only when BOTH endpoints have fresh OI
15:"""
16:from dataclasses import dataclass, field
17:
18:import numpy as np
19:import pandas as pd
20:
21:BARS_PER_DAY = 96
22:
23:
24:@dataclass(frozen=True)
25:class FeatureParams:
26:    adx_n: int = 14
27:    ema_fast: int = 20
28:    ema_slow: int = 50
29:    atr_n: int = 14
30:    bb_n: int = 20
31:    bb_k: float = 2.0
32:    q_window: int = 30 * BARS_PER_DAY          # 30d rolling window for percentiles
33:    q_min_periods_fuel: int = 20 * BARS_PER_DAY  # fuel deadzone tolerates shorter history (live mode)
34:    oi_lookback: int = 8                        # dOI / dprice lookback, candles
35:    dead_q: float = 0.25                        # deadzone quantile for |dOI%| and |dprice|
36:    burn_in: int = 35 * BARS_PER_DAY
37:
38:
39:DEFAULT_FP = FeatureParams()
40:
41:
42:def wilder(s: pd.Series, n: int) -> pd.Series:
43:    """Wilder smoothing (RMA) = EMA with alpha=1/n, forward-recursive (causal)."""
44:    return s.ewm(alpha=1.0 / n, adjust=False, min_periods=n).mean()
45:
46:
47:def adx_di(h: pd.Series, l: pd.Series, c: pd.Series, n: int):
48:    up = h.diff()
49:    dn = -l.diff()
50:    # NaN inputs (missing bars) must stay NaN — NaN>NaN is False, which would otherwise
51:    # inject fake zero-directional-movement observations into the Wilder recursion
52:    ok = up.notna() & dn.notna()
53:    pdm = up.where((up > dn) & (up > 0), 0.0).where(ok)
54:    ndm = dn.where((dn > up) & (dn > 0), 0.0).where(ok)
55:    tr = pd.concat([h - l, (h - c.shift(1)).abs(), (l - c.shift(1)).abs()], axis=1).max(axis=1)
56:    atr = wilder(tr, n)
57:    pdi = 100 * wilder(pdm, n) / atr
58:    ndi = 100 * wilder(ndm, n) / atr
59:    dx = 100 * (pdi - ndi).abs() / (pdi + ndi).replace(0, np.nan)
60:    adx = wilder(dx, n)
61:    return adx, pdi, ndi, atr
62:
63:
64:def past_pct_rank(s: pd.Series, window: int, min_periods: int) -> pd.Series:
65:    """Percentile of the current value against the strictly-past part of the rolling window."""
66:    r = s.rolling(window, min_periods=min_periods).rank(pct=True)
67:    cnt = s.rolling(window, min_periods=min_periods).count()
68:    return ((r * cnt - 1) / (cnt - 1)).where(cnt > 1)
69:
70:
71:def compute(df: pd.DataFrame, fp: FeatureParams = DEFAULT_FP, oi_col: str = "oi") -> pd.DataFrame:
72:    """df: build_dataset output (index=close ts). Returns feature frame on the same index."""
73:    out = pd.DataFrame(index=df.index)
74:    c, h, l = df["close"], df["high"], df["low"]
75:
76:    adx, pdi, ndi, atr = adx_di(h, l, c, fp.adx_n)
77:    ema_f = c.ewm(span=fp.ema_fast, adjust=False, min_periods=fp.ema_fast).mean()
78:    ema_s = c.ewm(span=fp.ema_slow, adjust=False, min_periods=fp.ema_slow).mean()
79:    out["adx"] = adx
80:    out["di_diff"] = pdi - ndi
81:    out["m"] = (ema_f - ema_s) / atr.replace(0, np.nan)
82:
83:    # volatility percentile blend (strictly-past distributions). min_periods gets 5% slack:
84:    # with min_periods == window, ONE missing bar blanks vol_pct for a full window length
85:    # (30 days) — the classifier then cold-resets for that whole stretch
86:    mp_vol = max(2, int(fp.q_window * 0.95))
87:    mid = c.rolling(fp.bb_n, min_periods=fp.bb_n).mean()
88:    sd = c.rolling(fp.bb_n, min_periods=fp.bb_n).std()
89:    bbw = (2 * fp.bb_k * sd) / mid.replace(0, np.nan)
90:    atrp = atr / c
91:    out["bbw_pct"] = past_pct_rank(bbw, fp.q_window, mp_vol)
92:    out["atrp_pct"] = past_pct_rank(atrp, fp.q_window, mp_vol)
93:    out["vol_pct"] = 0.5 * out["bbw_pct"] + 0.5 * out["atrp_pct"]
94:
95:    # fuel: relative dOI over k candles, both endpoints fresh
96:    k = fp.oi_lookback
97:    out["dprice"] = c / c.shift(k) - 1
98:    if oi_col in df.columns:
99:        oi = df[oi_col]
100:        if oi_col == "oi" and "oi_fresh" in df.columns:
101:            fresh = df["oi_fresh"]
102:        elif "bar_missing" in df.columns:
103:            fresh = oi.notna() & ~df["bar_missing"]  # same staleness rule as the main run
104:        else:
105:            fresh = oi.notna()
106:        doi = (oi - oi.shift(k)) / oi.shift(k)
107:        doi_ok = fresh & fresh.shift(k, fill_value=False)
108:        out["doi"] = doi.where(doi_ok)
109:    else:
110:        out["doi"] = np.nan  # degrade path: no OI at all
111:
112:    dz_doi = out["doi"].abs().rolling(fp.q_window, min_periods=fp.q_min_periods_fuel) \
113:        .quantile(fp.dead_q).shift(1)
114:    dz_dp = out["dprice"].abs().rolling(fp.q_window, min_periods=mp_vol) \
115:        .quantile(fp.dead_q).shift(1)
116:
117:    # quadrant codes: 0 no-fuel/deadzone/missing, 1 new-longs, 2 new-shorts,
118:    #                 3 short-covering, 4 long-liquidation
119:    d, p = out["doi"], out["dprice"]
120:    valid = d.notna() & dz_doi.notna() & dz_dp.notna() & (d.abs() >= dz_doi) & (p.abs() >= dz_dp)
121:    quad = np.select(
122:        [valid & (d > 0) & (p > 0), valid & (d > 0) & (p < 0),
123:         valid & (d < 0) & (p > 0), valid & (d < 0) & (p < 0)],
124:        [1, 2, 3, 4], default=0)
125:    out["quadrant"] = quad
126:    out["fuel_defined"] = d.notna() & dz_doi.notna()  # OI usable at all (deadzone still counts)
127:
128:    # funding percentile (strictly-past); label-inert by design, confidence-only
129:    if "funding" in df.columns and df["funding"].notna().any():
130:        out["funding_pct"] = past_pct_rank(df["funding"], fp.q_window, fp.q_min_periods_fuel)
131:    else:
132:        out["funding_pct"] = np.nan
133:
134:    out["close"] = c
135:    out["bar_missing"] = df["bar_missing"] if "bar_missing" in df.columns else False
136:    return out

