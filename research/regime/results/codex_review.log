382:def posthoc(symbol: str, horizons=(4, 16, 96)):
383:    """Post-hoc label audit: was each state RIGHT about the market's character?
384:    For every candle labeled state S, the realized return over the NEXT h bars.
385:    Uses future data BY DESIGN — this is a retrospective audit of past labels
386:    (published as diagnostics), never a feature; the classifier contract is untouched."""
387:    df, excluded, _ = load(symbol)
388:    feat, f, b2, b1 = tracks(df)
389:    F = trim(f)["regime"]
390:    exc = full_excluded(excluded, trim(f))
391:    lab = F.to_numpy(object)
392:    c = df["close"].iloc[BURN:].to_numpy(float)
393:    out = {"symbol": symbol, "horizons_bars": list(horizons), "states": {}}
394:    for state in classifier.REGIMES:
395:        base = (~pd.isna(lab)) & (lab == state) & ~exc
396:        row = {}
397:        for h in horizons:
398:            mask = base.copy()
399:            mask[-h:] = False
400:            r = (np.roll(c, -h) / c - 1.0)[mask]  # wrapped tail rows are masked off
401:            row[str(h)] = {
402:                "n": int(mask.sum()),
403:                "median_ret_pct": round(float(np.median(r)) * 100, 3),
404:                "share_up": round(float((r > 0).mean()), 3),
405:                "iqr_pct": [round(float(np.percentile(r, 25)) * 100, 3),
406:                            round(float(np.percentile(r, 75)) * 100, 3)],
407:                "abs_move_med_pct": round(float(np.median(np.abs(r))) * 100, 3),
408:            }
409:        out["states"][state] = row
410:    RESULTS.mkdir(exist_ok=True)
411:    (RESULTS / f"{symbol}_posthoc.json").write_text(json.dumps(out, indent=1))
412:
413:    names = {"TREND_UP": "상승추세", "TREND_DOWN": "하락추세", "SQUEEZE": "수렴",
414:             "RANGE": "박스권", "CHOP": "난장판"}
415:    hours = {4: "1시간", 16: "4시간", 96: "24시간"}
416:    print(f"\n[{symbol}] 상태별 사후 성과 — '라벨이 붙은 뒤 실제로 어떻게 갔나'")
417:    print(f"{'상태':12s}" + "".join(f"{hours.get(h, str(h)+'봉'):>26s}" for h in horizons))
418:    for state in classifier.REGIMES:
419:        cells = []
420:        for h in horizons:
421:            d = out["states"][state][str(h)]
422:            cells.append(f"중앙 {d['median_ret_pct']:+.2f}% ↑비율 {d['share_up']:.0%} "
423:                         f"|폭| {d['abs_move_med_pct']:.2f}%")
424:        print(f"{names[state]:12s}" + "".join(f"{s:>26s}" for s in cells))
425:    return out
