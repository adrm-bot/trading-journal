76:def read_klines_raw(symbol: str, start: str | None = None, end: str | None = None) -> pd.DataFrame:
77:    """Kline rows keyed by open_ts (pre-grid) — the cut/poison unit for look-ahead tests."""
78:    files = [f for f in sorted((RAW / symbol / "klines").glob("*.zip")) if _in_range(f, start, end)]
79:    if not files:
80:        raise FileNotFoundError(f"no kline zips for {symbol}")
81:    parts = []
82:    for f in files:
83:        df = _read_zip_csv(f)
84:        df.columns = KLINE_COLS[: len(df.columns)]
85:        df["open_ts"] = _epoch_to_utc(df["open_time"])
86:        parts.append(df[["open_ts", "open", "high", "low", "close", "volume"]])
87:    k = pd.concat(parts, ignore_index=True)
88:    for c in ["open", "high", "low", "close", "volume"]:
89:        k[c] = k[c].astype("float64")
