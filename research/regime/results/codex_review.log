287:
288:def collapse_events(conf: pd.Series, fuel_avail: pd.Series, excluded: np.ndarray,
289:                    q_window=2880, debounce=2, pad=96):
290:    """Collapse = confidence crossing below its own past-only rolling q20, needing `debounce`
291:    consecutive bars; the event is stamped at the bar where the criterion is SATISFIED.
292:    Events near data gaps or fuel-availability boundaries are masked."""
293:    thr = conf.rolling(q_window, min_periods=q_window).quantile(0.2).shift(1)
294:    below = (conf < thr).to_numpy(bool)
295:    ok = np.zeros(len(conf), dtype=bool)
296:    run = 0
297:    for i, b in enumerate(below):
298:        run = run + 1 if b else 0
299:        if run == debounce:  # stamped at satisfaction bar, never back-dated
300:            ok[i] = True
301:    # mask around gaps and availability flips
302:    bad = excluded.copy()
303:    av = fuel_avail.to_numpy(bool)
304:    flips = np.flatnonzero(av[1:] != av[:-1]) + 1
305:    for i in np.concatenate([flips, np.flatnonzero(excluded)]):
306:        bad[max(0, i - pad):i + pad] = True
307:    ok &= ~bad
308:    return np.flatnonzero(ok)
309:
310:
311:def collapse_metrics(ev_idx: np.ndarray, trans_idx: np.ndarray, n: int, W=96):
312:    """Convention: a collapse stamped exactly ON a transition bar counts as a lead-0 hit,
313:    on BOTH sides (precision via side='left' on transitions, recall via side='right' on
314:    events — asymmetric sides would silently deflate recall for coincident events)."""
315:    if len(ev_idx) == 0 or len(trans_idx) == 0:
316:        return {"n_events": int(len(ev_idx)), "n_transitions": int(len(trans_idx)),
317:                "precision": np.nan, "recall": np.nan, "median_lead": np.nan}
318:    t = np.sort(trans_idx)
319:    pos = np.searchsorted(t, ev_idx, side="left")
320:    dist = np.where(pos < len(t), t[np.minimum(pos, len(t) - 1)] - ev_idx, n)
321:    hits = dist <= W
322:    e = np.sort(ev_idx)
323:    pos_e = np.searchsorted(e, t, side="right")
324:    prev_ev = np.where(pos_e > 0, t - e[np.maximum(pos_e - 1, 0)], n)
325:    covered = prev_ev <= W
326:    return {"n_events": int(len(ev_idx)), "n_transitions": int(len(t)),
327:            "precision": float(hits.mean()),
328:            "recall": float(covered.mean()),
329:            "median_lead": float(np.median(dist[hits])) if hits.any() else np.nan}
330:
331:
332:def collapse_stage(symbol: str, n_shifts=200, seed=43, W=96):
333:    df, excluded, _ = load(symbol)
334:    feat, f, b2, b1 = tracks(df)
335:    conf = trim(f)["confidence"]
336:    fuel_avail = trim(f)["fuel_available"]
337:    exc = full_excluded(excluded, trim(f))
338:    B1 = trim(b1)
339:    lab = B1.to_numpy(object)
340:    valid = ~pd.isna(lab)
341:    trans = np.flatnonzero(valid[1:] & valid[:-1] & (lab[1:] != lab[:-1])) + 1
342:    n = len(conf)
343:
344:    ev = collapse_events(conf, fuel_avail, exc)
345:    obs = collapse_metrics(ev, trans, n, W)
346:    if len(ev) == 0 or np.isnan(obs["precision"]):
347:        out = {"symbol": symbol, "observed": obs, "p_precision": None, "p_recall": None,
348:               "note": "no collapse events — p undefined"}
349:        RESULTS.mkdir(exist_ok=True)
350:        (RESULTS / f"{symbol}_collapse.json").write_text(json.dumps(out, indent=1))
351:        return out
352:
353:    g = np.random.default_rng(seed)
354:    null_prec, null_lead, null_rec = [], [], []
355:    for _ in range(n_shifts):
356:        s = int(g.integers(W, n - W))
357:        ev_s = (ev + s) % n
358:        m = collapse_metrics(np.sort(ev_s), trans, n, W)
359:        null_prec.append(m["precision"])
360:        null_rec.append(m["recall"])
361:        if not np.isnan(m["median_lead"]):
362:            null_lead.append(m["median_lead"])
363:    p_prec = (1 + sum(1 for x in null_prec if x >= obs["precision"])) / (n_shifts + 1)
364:    p_rec = (1 + sum(1 for x in null_rec if x >= obs["recall"])) / (n_shifts + 1)
365:
366:    # funding ablation: same angle with the funding modifier off
367:    f_nf = classifier.classify(feat, use_funding=False)
368:    ev_nf = collapse_events(trim(f_nf)["confidence"], trim(f_nf)["fuel_available"], exc)
369:    obs_nf = collapse_metrics(ev_nf, trans, n, W)
370:
371:    out = {"symbol": symbol, "window_bars": W, "observed": obs,
372:           "null": {"precision_mean": float(np.mean(null_prec)),
373:                    "recall_mean": float(np.mean(null_rec)),
374:                    "median_lead_mean": float(np.mean(null_lead)) if null_lead else np.nan},
375:           "p_precision": p_prec, "p_recall": p_rec,
376:           "funding_ablation": obs_nf}
377:    RESULTS.mkdir(exist_ok=True)
378:    (RESULTS / f"{symbol}_collapse.json").write_text(json.dumps(out, indent=1))
379:    return out
