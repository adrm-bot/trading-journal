215:def null_run(symbol: str, n_shifts=200, seed=42):
216:    """Circular time-shift null: roll the OI series (alignment broken, autocorrelation kept),
217:    rerun the FULL fused pipeline, pooled enter median lead vs B1 per shift.
218:    p = P(null OI-marginal >= observed OI-marginal)."""
219:    df, excluded, _ = load(symbol)
220:    feat, f, b2, b1 = tracks(df)
221:    idx = trim(f).index
222:    exc = full_excluded(excluded, trim(f))
223:    B1 = trim(b1)
224:    obs = pair_stats(B1, trim(f)["regime"], idx, exc)
225:    obs_med = float(np.median(np.concatenate([obs[c]["leads"] for c in CLASSES])))
226:    b2s = pair_stats(B1, trim(b2)["regime"], idx, exc)
227:    b2_med = float(np.median(np.concatenate([b2s[c]["leads"] for c in CLASSES])))
228:    obs_marginal = obs_med - b2_med
229:
230:    obs_cls = {c: float(np.median(obs[c]["leads"])) - float(np.median(b2s[c]["leads"]))
231:               for c in CLASSES}
232:
233:    g = np.random.default_rng(seed)
234:    n = len(df)
235:    lo, hi = 192, 96 * 90  # 2 days .. 90 days
236:    null_marginals = []
237:    null_cls = {c: [] for c in CLASSES}
238:    oi = df["oi"].to_numpy()
239:    fresh = df["oi_fresh"].to_numpy()
240:    bar_missing = df["bar_missing"].to_numpy(bool)
241:    k_lb = features.DEFAULT_FP.oi_lookback
242:    for i in range(n_shifts):
243:        s = int(g.integers(lo, hi)) * (1 if g.random() < 0.5 else -1)
244:        df2 = df.copy()
245:        df2["oi"] = np.roll(oi, s)
246:        fresh2 = np.roll(fresh, s).copy()
247:        # mask the wrap seam: dOI across it is a fake discontinuity, not misalignment
248:        seam = s % n
249:        fresh2[max(0, seam - k_lb):min(n, seam + k_lb + 1)] = False
250:        df2["oi_fresh"] = fresh2
251:        feat2 = features.compute(df2)
252:        f2 = classifier.classify(feat2)
253:        # exclusion mask must follow the ROLLED freshness (same filtering rule as observed)
254:        exc2 = (bar_missing | ~fresh2)[BURN:] | pd.isna(trim(f2)["regime"].to_numpy(object))
255:        p2 = pair_stats(B1, trim(f2)["regime"], idx, exc2)
256:        leads2 = np.concatenate([p2[c]["leads"] for c in CLASSES])
257:        if len(leads2):
258:            null_marginals.append(float(np.median(leads2)) - b2_med)
259:        for c in CLASSES:
260:            if len(p2[c]["leads"]):
261:                null_cls[c].append(float(np.median(p2[c]["leads"]))
262:                                   - float(np.median(b2s[c]["leads"])))
263:        if (i + 1) % 20 == 0:
264:            print(f"  null {i + 1}/{n_shifts}", flush=True)
265:    null_arr = np.array(null_marginals)
266:    p = (1 + int((null_arr >= obs_marginal).sum())) / (len(null_arr) + 1)
267:    per_class = {}
268:    for c in CLASSES:
269:        arr = np.array(null_cls[c])
270:        if len(arr) == 0:
271:            per_class[c] = {"observed": obs_cls[c], "n_null": 0, "p_one_sided": None,
272:                            "note": "degenerate null — no replicates produced leads"}
273:            continue
274:        per_class[c] = {"observed": obs_cls[c], "n_null": int(len(arr)),
275:                        "null_median": float(np.median(arr)),
276:                        "null_iqr": [float(np.percentile(arr, 25)), float(np.percentile(arr, 75))],
277:                        "p_one_sided": (1 + int((arr >= obs_cls[c]).sum())) / (len(arr) + 1)}
278:    out = {"symbol": symbol, "observed_F_median": obs_med, "B2_median": b2_med,
279:           "observed_OI_marginal": obs_marginal,
280:           "null_n": len(null_arr), "null_median": float(np.median(null_arr)),
281:           "null_iqr": [float(np.percentile(null_arr, 25)), float(np.percentile(null_arr, 75))],
282:           "p_one_sided": p, "per_class": per_class}
283:    RESULTS.mkdir(exist_ok=True)
284:    (RESULTS / f"{symbol}_null.json").write_text(json.dumps(out, indent=1))
285:    return out
