185:def runs_of(mask: pd.Series) -> list:
186:    """Contiguous True-runs of a boolean series -> [(start_iso, end_iso, n), ...]."""
187:    out = []
188:    idx = mask.index
189:    arr = mask.to_numpy()
190:    start = None
191:    for i, v in enumerate(arr):
192:        if v and start is None:
193:            start = i
194:        elif not v and start is not None:
195:            out.append((str(idx[start]), str(idx[i - 1]), i - start))
196:            start = None
197:    if start is not None:
198:        out.append((str(idx[start]), str(idx[-1]), len(arr) - start))
199:    return out
