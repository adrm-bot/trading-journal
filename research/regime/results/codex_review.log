171:              f"CI[{lo},{hi}] null_med {out['variants'][kind]['null_median']} p={p} "
172:              f"churn {churn_v:.2f}", flush=True)
173:
174:    out["baseline_churn"] = {"F": round(churn_std, 3), "B2": round(churn_b2, 3)}
175:    run_all.RESULTS.mkdir(exist_ok=True)
176:    (run_all.RESULTS / f"{sym}_altaxes.json").write_text(json.dumps(out, indent=1))
177:    print(json.dumps(out, indent=1))
