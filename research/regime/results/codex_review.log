96:def cut_points(full_f):
97:    pts = [pd.Timestamp("2023-08-01 00:00", tz="UTC"),   # month zip boundary
98:           pd.Timestamp("2024-01-01 00:00", tz="UTC"),   # year/month boundary
99:           pd.Timestamp("2023-09-10 16:00", tz="UTC"),   # funding boundary
100:           pd.Timestamp("2024-02-16 18:00", tz="UTC")]   # inside the OI outage
101:    lab = full_f["regime"]
102:    trans = lab.notna() & lab.shift().notna() & (lab != lab.shift())
103:    t_idx = lab.index[trans]
104:    t_idx = t_idx[t_idx > pd.Timestamp("2023-09-01", tz="UTC")]
105:    pts += [t_idx[i] + BAR for i in (0, len(t_idx) // 2, len(t_idx) - 1)]
106:    return pts
