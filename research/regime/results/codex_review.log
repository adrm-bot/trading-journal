2:"""B1 baseline: the classic ADX regime detector, nothing else.
3:
4:TREND_UP   if ADX >= 25 and DI+ > DI-
5:TREND_DOWN if ADX >= 25 and DI+ < DI-
6:SIDEWAYS   otherwise
7:
8:Deliberately dumb and slow-to-confirm: this is the reference clock the fused classifier is
9:measured against. Computed from the SAME feature frame and stamped at the same candle-close
10:timestamps as the fused track (a per-track stamping difference would bias every lead by a
11:constant).
12:"""
13:import numpy as np
14:import pandas as pd
15:
16:ADX_CUT = 25.0
17:
18:
19:def classify_b1(feat: pd.DataFrame) -> pd.Series:
20:    adx = feat["adx"].to_numpy(float)
21:    di = feat["di_diff"].to_numpy(float)
22:    valid = ~(np.isnan(adx) | np.isnan(di))
23:    lab = np.where(~valid, None,
24:                   np.where((adx >= ADX_CUT) & (di > 0), "TREND_UP",
25:                            np.where((adx >= ADX_CUT) & (di < 0), "TREND_DOWN", "SIDEWAYS")))
26:    return pd.Series(lab, index=feat.index, name="regime")

