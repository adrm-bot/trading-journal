107:    k = k.set_index("ts").drop(columns=["open_ts"]).sort_index()
108:    grid = pd.date_range(k.index[0], k.index[-1], freq="15min", tz="UTC", unit="ns")
109:    k = k.reindex(grid)
110:    k.index.name = "ts"
111:    k["bar_missing"] = k["close"].isna()
