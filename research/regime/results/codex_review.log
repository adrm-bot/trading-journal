1:#!/usr/bin/env python3
2:"""Lead-lag harness: EPISODE (interval) matching between label tracks.
3:
4:Point-event nearest matching is gameable — a twitchy track buys "lead" with churn (multiple
5:flips before every slow baseline confirmation; the just-before flip gets matched). Episodes
6:are the honest unit: regimes are intervals, and the question is "when did the fused track's
7:episode corresponding to this baseline trend episode BEGIN?"
8:
9:- tracks are mapped to the common 3-superstate alphabet {UP, DOWN, NT}
10:- trend episodes = maximal runs of UP or DOWN, length >= min_len (blips are not episodes;
11:  unmatched fused episodes are counted as FALSE ALARMS, a first-class metric)
12:- 1:1 matching per class by largest temporal overlap, overlap >= min_overlap of the shorter
13:  episode; no horizon parameter exists
14:- lead = baseline_start - fused_start (positive = fused earlier); episode ends are compared
15:  separately (exit timing)
16:- uncertainty: month-level cluster bootstrap (events are era-correlated; event-level blocks
17:  undercover); OI attribution uses PAIRED month resampling of (F leads, B2 leads)
18:- null for OI: circular time-shift of the OI series (preserves autocorrelation, breaks only
19:  alignment) rerun through the full fused pipeline
20:"""
21:from dataclasses import dataclass
22:
23:import numpy as np
24:import pandas as pd
25:
26:SUPER = {"TREND_UP": "UP", "TREND_DOWN": "DOWN"}
27:
28:
29:@dataclass(frozen=True)
30:class MatchParams:
31:    min_len: int = 4          # candles; sub-hour blips are noise, not episodes
32:    min_overlap: float = 0.25  # fraction of the shorter episode
33:    gap_pad: int = 8          # exclude episodes starting within +-pad of a data gap
34:
35:
36:DEFAULT_MP = MatchParams()
37:
38:
39:def to_super(labels) -> np.ndarray:
40:    out = np.empty(len(labels), dtype=object)
41:    for i, x in enumerate(labels):
42:        out[i] = None if pd.isna(x) else SUPER.get(x, "NT")
43:    return out
44:
45:
46:def episodes(sup: np.ndarray, cls: str, min_len: int) -> list:
47:    """Maximal runs of `cls`, length >= min_len -> [(start, end_inclusive), ...]"""
48:    out = []
49:    start = None
50:    for i, v in enumerate(sup):
51:        if v == cls and start is None:
52:            start = i
53:        elif v != cls and start is not None:
54:            if i - start >= min_len:
55:                out.append((start, i - 1))
56:            start = None
57:    if start is not None and len(sup) - start >= min_len:
58:        out.append((start, len(sup) - 1))
59:    return out
60:
61:
62:def match(base_eps: list, fused_eps: list, min_overlap: float):
63:    """1:1 greedy by overlap desc (deterministic tiebreak by index). Returns
64:    (pairs [(bi, fi, ov)], unmatched_base_idx, unmatched_fused_idx)."""
65:    cand = []
66:    for bi, (bs, be) in enumerate(base_eps):
67:        for fi, (fs, fe) in enumerate(fused_eps):
68:            ov = min(be, fe) - max(bs, fs) + 1
69:            if ov <= 0:
70:                continue
71:            shorter = min(be - bs, fe - fs) + 1
72:            if ov >= min_overlap * shorter:
73:                cand.append((ov, bi, fi))
74:    cand.sort(key=lambda t: (-t[0], t[1], t[2]))
75:    used_b, used_f, pairs = set(), set(), []
76:    for ov, bi, fi in cand:
77:        if bi in used_b or fi in used_f:
78:            continue
79:        used_b.add(bi)
80:        used_f.add(fi)
81:        pairs.append((bi, fi, ov))
82:    un_b = [i for i in range(len(base_eps)) if i not in used_b]
83:    un_f = [i for i in range(len(fused_eps)) if i not in used_f]
84:    return pairs, un_b, un_f
85:
86:
87:def _near_gap(ep, excluded: np.ndarray, pad: int) -> bool:
88:    s = ep[0]
89:    lo, hi = max(0, s - pad), min(len(excluded), s + pad + 1)
90:    return bool(excluded[lo:hi].any())
91:
92:
93:def class_stats(base_sup: np.ndarray, fused_sup: np.ndarray, cls: str,
94:                mp: MatchParams = DEFAULT_MP, excluded: np.ndarray | None = None) -> dict:
95:    """Lead/miss/false-alarm stats for one episode class ('UP' or 'DOWN')."""
96:    n = len(base_sup)
97:    be = episodes(base_sup, cls, mp.min_len)
98:    fe = episodes(fused_sup, cls, mp.min_len)
99:    if excluded is not None:
100:        n_excl_b = sum(_near_gap(e, excluded, mp.gap_pad) for e in be)
101:        n_excl_f = sum(_near_gap(e, excluded, mp.gap_pad) for e in fe)
102:        be = [e for e in be if not _near_gap(e, excluded, mp.gap_pad)]
103:        fe = [e for e in fe if not _near_gap(e, excluded, mp.gap_pad)]
104:    else:
105:        n_excl_b = n_excl_f = 0
106:    pairs, un_b, un_f = match(be, fe, mp.min_overlap)
107:    leads = np.array([be[bi][0] - fe[fi][0] for bi, fi, _ in pairs])
108:    end_deltas = np.array([be[bi][1] - fe[fi][1] for bi, fi, _ in pairs])
109:    starts_b = [be[bi][0] for bi, fi, _ in pairs]
110:    return {
111:        "class": cls,
112:        "n_base": len(be), "n_fused": len(fe), "n_matched": len(pairs),
113:        "n_miss": len(un_b), "n_false": len(un_f),
114:        "n_excluded_base": n_excl_b, "n_excluded_fused": n_excl_f,
115:        "false_per_100c": len(un_f) / n * 100,
116:        "leads": leads, "end_deltas": end_deltas, "pair_base_starts": starts_b,
117:    }
118:
119:
120:def churn3(sup: np.ndarray) -> float:
121:    """Label flips per 100 candles on the 3-superstate alphabet (None-safe)."""
122:    v = [x for x in sup if x is not None]
123:    if len(v) < 2:
124:        return 0.0
125:    flips = sum(a != b for a, b in zip(v, v[1:]))
126:    return flips / len(v) * 100
127:
128:
129:def flap_rate(sup: np.ndarray) -> float:
130:    """Fraction of label changes reversed within 2 candles (boundary flapping)."""
131:    v = [x for x in sup if x is not None]
132:    changes = [i for i in range(1, len(v)) if v[i] != v[i - 1]]
133:    if not changes:
134:        return 0.0
135:    revert = sum(1 for i in changes
136:                 if (i + 1 < len(v) and v[i + 1] == v[i - 1])
137:                 or (i + 2 < len(v) and v[i + 2] == v[i - 1] and v[i + 1] == v[i]))
138:    return revert / len(changes)
139:
140:
141:def hodges_lehmann(x: np.ndarray) -> float:
142:    if len(x) == 0:
143:        return np.nan
144:    i, j = np.triu_indices(len(x))
145:    return float(np.median((x[i] + x[j]) / 2.0))
146:
147:
148:def month_keys(index: pd.DatetimeIndex, starts: list) -> np.ndarray:
149:    return np.array([f"{index[s]:%Y-%m}" for s in starts])
150:
151:
152:def month_bootstrap_median(leads: np.ndarray, months: np.ndarray,
153:                           n_boot: int = 2000, seed: int = 11):
154:    """Cluster bootstrap over calendar months: resample months, pool their leads, median."""
155:    if len(leads) == 0:
156:        return (np.nan, np.nan)
157:    uniq = np.unique(months)
158:    g = np.random.default_rng(seed)
159:    by_month = {m: leads[months == m] for m in uniq}
160:    meds = []
161:    for _ in range(n_boot):
162:        pick = g.choice(uniq, size=len(uniq), replace=True)
163:        pool = np.concatenate([by_month[m] for m in pick])
164:        meds.append(np.median(pool))
165:    return (float(np.percentile(meds, 2.5)), float(np.percentile(meds, 97.5)))
166:
167:
168:def paired_month_bootstrap_diff(leads_f, months_f, leads_b, months_b,
169:                                n_boot: int = 2000, seed: int = 11):
170:    """CI for median(F leads) - median(B2 leads) with the SAME month resample on both sides
171:    (preserves era pairing)."""
172:    uniq = np.unique(np.concatenate([months_f, months_b]))
173:    g = np.random.default_rng(seed)
174:    f_by = {m: leads_f[months_f == m] for m in uniq}
175:    b_by = {m: leads_b[months_b == m] for m in uniq}
176:    diffs = []
177:    for _ in range(n_boot):
178:        pick = g.choice(uniq, size=len(uniq), replace=True)
179:        pf = np.concatenate([f_by[m] for m in pick]) if any(len(f_by[m]) for m in pick) else np.array([])
180:        pb = np.concatenate([b_by[m] for m in pick]) if any(len(b_by[m]) for m in pick) else np.array([])
181:        if len(pf) == 0 or len(pb) == 0:
182:            continue
183:        diffs.append(np.median(pf) - np.median(pb))
184:    if not diffs:
185:        return (np.nan, np.nan, np.nan)
186:    return (float(np.median(diffs)), float(np.percentile(diffs, 2.5)),
187:            float(np.percentile(diffs, 97.5)))
188:
189:
190:def summarize(leads: np.ndarray) -> dict:
191:    if len(leads) == 0:
192:        return {"n": 0, "median": np.nan, "iqr": (np.nan, np.nan), "hl": np.nan}
193:    return {"n": int(len(leads)),
194:            "median": float(np.median(leads)),
195:            "iqr": (float(np.percentile(leads, 25)), float(np.percentile(leads, 75))),
196:            "hl": hodges_lehmann(leads)}

