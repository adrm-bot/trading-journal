1:"""The measuring instrument is validated BEFORE it touches real data.
2:
3:Three mandatory gates (a clean known-lead recovery alone would also pass a matcher that is
4:gameable by churn — that is exactly the failure mode episode matching exists to close):
5:  (a) noisy NON-leader: extra spurious episodes, zero injected lead -> median lead ~ 0,
6:      false alarms reported
7:  (b) noisy leader: injected lead k + spurious episodes -> recovers k without inflation
8:  (c) gap case: episodes near excluded bars are dropped and counted, remaining leads intact
9:"""
10:import numpy as np
11:
12:import leadlag
13:from leadlag import MatchParams
14:
15:
16:def build_track(n=20000, ep_len=40, gap_len=80, seed=3):
17:    """Baseline: alternating NT blocks and UP/DOWN episodes."""
18:    g = np.random.default_rng(seed)
19:    sup = np.array(["NT"] * n, dtype=object)
20:    pos, cls = gap_len, 0
21:    starts = []
22:    while pos + ep_len < n - gap_len:
23:        c = "UP" if cls % 2 == 0 else "DOWN"
24:        sup[pos:pos + ep_len] = c
25:        starts.append((pos, c))
26:        pos += ep_len + gap_len
27:        cls += 1
28:    return sup, starts
29:
30:
31:def shift_earlier(sup, k):
32:    """Fused track that enters (and exits) every episode k bars EARLIER."""
33:    out = np.roll(sup.copy(), -k)
34:    out[-k:] = "NT"
35:    return out
36:
37:
38:def inject_spurious(sup, n_spur, seed=9, length=6):
39:    g = np.random.default_rng(seed)
40:    out = sup.copy()
41:    n = len(out)
42:    added = 0
43:    tries = 0
44:    while added < n_spur and tries < n_spur * 50:
45:        tries += 1
46:        s = int(g.integers(0, n - length))
47:        seg = out[s - 2:s + length + 2]
48:        if all(x == "NT" for x in seg):  # only inside NT zones, not touching real episodes
49:            out[s:s + length] = g.choice(["UP", "DOWN"])
50:            added += 1
51:    assert added == n_spur
52:    return out
53:
54:
55:def median_lead(base, fused, mp=MatchParams(), excluded=None):
56:    leads = np.concatenate([
57:        leadlag.class_stats(base, fused, c, mp, excluded)["leads"] for c in ("UP", "DOWN")])
58:    return np.median(leads), leads
59:
60:
61:def test_clean_known_lead_recovered():
62:    base, _ = build_track()
63:    for k in (2, 5, 10):
64:        fused = shift_earlier(base, k)
65:        med, leads = median_lead(base, fused)
66:        assert med == k, f"expected lead {k}, got {med}"
67:        assert len(leads) > 100
68:
69:
70:def test_noisy_non_leader_reports_zero():
71:    base, _ = build_track()
72:    fused = inject_spurious(base, n_spur=120)  # ~75% extra episodes, ZERO real lead
73:    med, leads = median_lead(base, fused)
74:    assert abs(med) <= 1, f"churny non-leader must not fake lead, got median {med}"
75:    st = leadlag.class_stats(base, fused, "UP")
76:    assert st["n_false"] > 20, "spurious episodes must surface as false alarms"
77:
78:
79:def test_noisy_leader_recovers_k_without_inflation():
80:    base, _ = build_track()
81:    k = 5
82:    fused = inject_spurious(shift_earlier(base, k), n_spur=120)
83:    med, _ = median_lead(base, fused)
84:    assert abs(med - k) <= 1, f"expected ~{k}, got {med}"
85:
86:
87:def test_gap_exclusion():
88:    base, starts = build_track()
89:    k = 5
90:    fused = shift_earlier(base, k)
91:    excluded = np.zeros(len(base), dtype=bool)
92:    # kill the zone around the 3rd and 4th episode starts
93:    for s, _ in starts[2:4]:
94:        excluded[s - 10:s + 10] = True
95:    mp = MatchParams()
96:    st_up = leadlag.class_stats(base, fused, "UP", mp, excluded)
97:    st_dn = leadlag.class_stats(base, fused, "DOWN", mp, excluded)
98:    assert st_up["n_excluded_base"] + st_dn["n_excluded_base"] >= 2
99:    med = np.median(np.concatenate([st_up["leads"], st_dn["leads"]]))
100:    assert med == k, "exclusion must not distort surviving leads"
101:
102:
103:def test_direct_flip_is_two_episodes():
104:    sup = np.array(["NT"] * 20 + ["UP"] * 10 + ["DOWN"] * 10 + ["NT"] * 20, dtype=object)
105:    ups = leadlag.episodes(sup, "UP", 4)
106:    dns = leadlag.episodes(sup, "DOWN", 4)
107:    assert ups == [(20, 29)] and dns == [(30, 39)]
108:
109:
110:def test_blips_are_not_episodes():
111:    sup = np.array(["NT"] * 50, dtype=object)
112:    sup[10:12] = "UP"  # 2-bar blip < min_len 4
113:    assert leadlag.episodes(sup, "UP", 4) == []
114:
115:
