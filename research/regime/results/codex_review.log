1:"""THE look-ahead test. Any future reference anywhere in the pipeline must fail it.
2:
3:Operates on the RAW three tables (klines / metrics / funding) from the real archive, sliced to
4:2023-07 .. 2024-04 (contains month-file boundaries, funding times, label transitions, and the
5:2024-02-16 OI outage):
6:
7:- truncate mode: cut ALL three raw tables at wall-clock t*, rerun the full pipeline
8:  (assemble -> features -> classify F + B2 + B1); every output at ts <= t* must EXACTLY match
9:  the full run (labels/events: no tolerance; floats: atol 1e-12)
10:- poison mode: keep full length but replace every row after t* in all three tables with
11:  garbage; same assertion
12:- canary: a deliberately leaky pipeline (oi shifted -1 candle after the join) MUST be caught
13:  by the same machinery — proves the test can fail
14:
15:Cut points are adversarial, not uniform-random: month zip boundaries, a funding boundary,
16:inside the OI gap, and immediately after real label transitions.
17:"""
18:import numpy as np
19:import pandas as pd
20:import pytest
21:
22:import build_dataset as bd
23:import baseline
24:import classifier
25:import features
26:
27:SYMBOL = "BTCUSDT"
28:SLICE = ("2023-07-01", "2024-04-30")
29:BAR = pd.Timedelta(minutes=15)
30:
31:
32:@pytest.fixture(scope="module")
33:def raw():
34:    if not (bd.RAW / SYMBOL / "metrics").exists():
35:        pytest.skip("raw archive not downloaded")
36:    kraw = bd.read_klines_raw(SYMBOL, *SLICE)
37:    m, _, _ = bd.read_metrics(SYMBOL, *SLICE)
38:    fu = bd.read_funding(SYMBOL, *SLICE)
39:    return kraw, m, fu
40:
41:
42:def pipeline(kraw, m, fu, leak=False, cp=classifier.DEFAULT_CP):
43:    df = bd.assemble(kraw, m, fu)
44:    if leak:
45:        df["oi"] = df["oi"].shift(-1)  # deliberate future reference (canary)
46:    feat = features.compute(df)
47:    f = classifier.classify(feat, cp)
48:    b2 = classifier.classify(feat, cp, use_fuel=False)
49:    b1 = baseline.classify_b1(feat)
50:    return f, b2, b1
51:
52:
53:def cut(kraw, m, fu, tstar):
54:    return (kraw[kraw["open_ts"] + BAR <= tstar],
55:            m[m["snap_ts"] <= tstar],
56:            fu[fu["event_ts"] <= tstar])
57:
58:
59:def poison(kraw, m, fu, tstar):
60:    k2, m2, f2 = kraw.copy(), m.copy(), fu.copy()
61:    kf = k2["open_ts"] + BAR > tstar
62:    for col, fac in [("open", 7.0), ("high", 9.0), ("low", 0.5), ("close", 7.0), ("volume", 100.0)]:
63:        k2.loc[kf, col] *= fac
64:    m2.loc[m2["snap_ts"] > tstar, "oi"] *= 13.0
65:    f2.loc[f2["event_ts"] > tstar, "funding"] = 0.05
66:    return k2, m2, f2
