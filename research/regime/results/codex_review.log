68:def variant_feat(feat_std: pd.DataFrame, source: pd.Series, kind: str) -> pd.DataFrame:
69:    """Build the variant feature frame from a (possibly time-shifted) source series."""
70:    feat = feat_std.copy()
71:    if kind == "taker":
72:        pct = features.past_pct_rank(source, QW, MPF)
73:        quad = np.select([pct >= 0.75, pct <= 0.25], [1, 2], 0)
74:        feat["quadrant"] = quad
75:        feat["fuel_defined"] = pct.notna().to_numpy()
76:    elif kind == "lsr":
77:        d = source / source.shift(K) - 1.0
78:        dz = d.abs().rolling(QW, min_periods=MPF).quantile(0.25).shift(1)
79:        ok = d.notna() & dz.notna()
80:        quad = np.select([ok & (d >= dz), ok & (d <= -dz)], [1, 2], 0)
81:        feat["quadrant"] = quad
82:        feat["fuel_defined"] = ok.to_numpy()
83:    elif kind == "dvol":
84:        dp = features.past_pct_rank(source, QW, MPF)
85:        feat["vol_pct"] = (feat["bbw_pct"] + feat["atrp_pct"] + dp) / 3.0
86:    else:
87:        raise ValueError(kind)
88:    return feat
