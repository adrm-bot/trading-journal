1:#!/usr/bin/env python3
2:"""5-state regime classifier: per-axis score vectors -> weighted argmax + agreement confidence.
3:
4:Output contract: one row per candle (after burn-in), {regime, confidence in [0,1], timestamp}.
5:No forecasts, no price targets, no trade signals. This module NEVER imports the playbook.
6:
7:Design notes (adversarially reviewed, see NOTES.md):
8:- direction axis is agnostic among SQUEEZE/RANGE/CHOP; volatility axis is agnostic on trend —
9:  explicit templates keep all 5 states reachable
10:- fuel: only dOI-rising quadrants (new longs/new shorts) vote on the label; dOI-falling
11:  quadrants (short covering / long liquidation) are LABEL-INERT confidence trims, because in
12:  perp markets those are often the most violent trend-continuation legs
13:- funding is label-inert by construction (confidence-only)
14:- near-tie argmax prefers the incumbent state (zero-parameter anti-flap, distinct from
15:  min_dwell/confirm_bars which default OFF)
16:- hysteresis is an online FSM: a switch is stamped at the candle where it is confirmed,
17:  never back-dated
18:- degrade path: no usable OI -> fuel axis skipped, weights renormalized, flat confidence
19:  penalty, fuel_available flag emitted. The B2 ablation (use_fuel=False) is a legitimate
20:  UNPENALIZED 2-axis classifier — the penalty belongs to the production degrade path only.
21:"""
22:from dataclasses import dataclass
23:
24:import numpy as np
25:import pandas as pd
26:
27:REGIMES = ("TREND_UP", "TREND_DOWN", "SQUEEZE", "RANGE", "CHOP")
28:IDX = {r: i for i, r in enumerate(REGIMES)}
29:
30:
31:@dataclass(frozen=True)
32:class ClassifierParams:
33:    adx_lo: float = 20.0
34:    adx_scale: float = 15.0
35:    w_dir: float = 0.5
36:    w_vol: float = 0.3
37:    w_fuel: float = 0.2
38:    ramp_lo: tuple = (0.15, 0.25)    # vol_pct ramp: SQUEEZE membership
39:    ramp_hi: tuple = (0.75, 0.85)    # vol_pct ramp: CHOP membership
40:    near_tie: float = 0.02
41:    conf_doi_down: float = 0.85      # short-covering / long-liquidation trim (label-inert)
42:    conf_deadzone: float = 0.95      # no-fuel deadzone trim (spec sign table)
43:    funding_extreme: float = 0.95    # funding percentile beyond this = crowded
44:    conf_funding: float = 0.90       # trim on TREND confidence when crowded
45:    degrade_penalty: float = 0.80    # production degrade path only
46:    min_dwell: int = 0
47:    confirm_bars: int = 0
48:
49:
50:DEFAULT_CP = ClassifierParams()
51:
52:
53:def axis_scores(feat: pd.DataFrame, p: ClassifierParams, use_fuel: bool):
54:    """Return (scores n x 5 normalized, valid mask, fuel_mod, fuel_votes, fuel_available)."""
55:    n = len(feat)
56:    adx = feat["adx"].to_numpy(float)
57:    m = feat["m"].to_numpy(float)
58:    di = feat["di_diff"].to_numpy(float)
59:    v = feat["vol_pct"].to_numpy(float)
60:
61:    valid = ~(np.isnan(adx) | np.isnan(m) | np.isnan(v))
62:
63:    # --- direction axis ---
64:    a = np.clip((adx - p.adx_lo) / p.adx_scale, 0.0, 1.0)
65:    T = a * np.tanh(np.abs(m))
66:    agree = np.sign(di) == np.sign(m)
67:    T = np.where(agree, T, T * 0.5)
68:    dir_s = np.zeros((n, 5))
69:    dir_s[:, IDX["TREND_UP"]] = np.where(m > 0, T, 0.0)
70:    dir_s[:, IDX["TREND_DOWN"]] = np.where(m < 0, T, 0.0)
71:    rest = (1.0 - dir_s[:, 0] - dir_s[:, 1]) / 3.0
72:    for s in ("SQUEEZE", "RANGE", "CHOP"):
73:        dir_s[:, IDX[s]] = rest
74:
75:    # --- volatility axis ---
76:    lo0, lo1 = p.ramp_lo
77:    hi0, hi1 = p.ramp_hi
78:    muL = np.clip((lo1 - v) / (lo1 - lo0), 0.0, 1.0)
79:    muH = np.clip((v - hi0) / (hi1 - hi0), 0.0, 1.0)
80:    muM = np.clip(1.0 - muL - muH, 0.0, 1.0)
81:    vol_s = np.zeros((n, 5))
82:    vol_s[:, IDX["SQUEEZE"]] = muL
83:    vol_s[:, IDX["RANGE"]] = muM
84:    vol_s[:, IDX["CHOP"]] = muH
85:
86:    # --- fuel axis ---
87:    fuel_votes = np.zeros(n, dtype=bool)
88:    fuel_mod = np.ones(n)
89:    fuel_available = np.zeros(n, dtype=bool)
90:    fuel_s = np.zeros((n, 5))
91:    if use_fuel and "quadrant" in feat.columns:
92:        quad = feat["quadrant"].to_numpy()
93:        fuel_available = feat["fuel_defined"].to_numpy(bool)
94:        fuel_votes = fuel_available & ((quad == 1) | (quad == 2))
95:        fuel_s[quad == 1, IDX["TREND_UP"]] = 1.0
96:        fuel_s[quad == 2, IDX["TREND_DOWN"]] = 1.0
97:        fuel_mod = np.where(fuel_available & ((quad == 3) | (quad == 4)),
98:                            p.conf_doi_down, fuel_mod)
99:        fuel_mod = np.where(fuel_available & (quad == 0), p.conf_deadzone, fuel_mod)
100:
101:    w_present = p.w_dir + p.w_vol + np.where(fuel_votes, p.w_fuel, 0.0)
102:    scores = (p.w_dir * dir_s + p.w_vol * vol_s
103:              + p.w_fuel * fuel_s * fuel_votes[:, None]) / w_present[:, None]
104:    return scores, valid, fuel_mod, fuel_votes, fuel_available
105:
106:
107:def classify(feat: pd.DataFrame, p: ClassifierParams = DEFAULT_CP, *,
108:             use_fuel: bool = True, use_funding: bool = True,
109:             debug: bool = False) -> pd.DataFrame:
110:    """feat: features.compute() output. Returns DataFrame(regime, confidence) on feat.index.
111:
112:    Rows where core features are NaN (burn-in) get regime=None, confidence=NaN.
113:    Degrade path is PER-ROW and causal: any row without usable fuel (missing OI column,
114:    stale OI, deadzone-window warmup) gets the flat degrade penalty on confidence — no
115:    whole-series look-ahead decides the mode. The B2 ablation (use_fuel=False) stays
116:    unpenalized by definition.
117:    """
118:    scores, valid, fuel_mod, fuel_votes, fuel_available = axis_scores(feat, p, use_fuel)
119:    n = len(feat)
120:    fund = feat["funding_pct"].to_numpy(float) if "funding_pct" in feat.columns \
121:        else np.full(n, np.nan)
122:
123:    labels = np.full(n, -1, dtype=np.int8)
124:    conf = np.full(n, np.nan)
125:
126:    cur = -1
127:    pending, pend_count, since_switch = -1, 0, 10**9
128:    best_arr = np.argmax(scores, axis=1)  # first-max on ties (matches the Pine port)
129:    for t in range(n):
130:        if not valid[t]:
131:            cur, pending, pend_count, since_switch = -1, -1, 0, 10**9
132:            continue
133:        best = best_arr[t]
134:        # near-tie: prefer the incumbent
135:        cand = cur if (cur >= 0 and scores[t, cur] >= scores[t, best] - p.near_tie) else best
136:        if cur < 0:
137:            cur, since_switch = cand, 0
138:        elif cand != cur:
139:            if cand == pending:
140:                pend_count += 1
141:            else:
142:                pending, pend_count = cand, 1
143:            if pend_count >= p.confirm_bars + 1 and since_switch >= p.min_dwell:
144:                cur, since_switch = cand, 0
145:                pending, pend_count = -1, 0
146:        else:
147:            pending, pend_count = -1, 0
148:        since_switch += 1
149:        labels[t] = cur
150:
151:        agreement = scores[t, cur]
152:        runner = max(scores[t, s] for s in range(5) if s != cur)
153:        margin = 1.0 - 0.5 * (runner / agreement if agreement > 1e-12 else 2.0)
154:        c = agreement * margin * fuel_mod[t]
155:        if use_funding and not np.isnan(fund[t]) and cur in (0, 1):
156:            if fund[t] >= p.funding_extreme or fund[t] <= 1.0 - p.funding_extreme:
157:                c *= p.conf_funding
158:        if use_fuel and not fuel_available[t]:
159:            c *= p.degrade_penalty  # per-row causal degrade (fuel wanted but unusable here)
160:        conf[t] = min(max(c, 0.0), 1.0)
161:
162:    regime = pd.array([REGIMES[i] if i >= 0 else None for i in labels])
163:    out = pd.DataFrame({"regime": regime, "confidence": conf}, index=feat.index)
164:    out["fuel_available"] = fuel_available if use_fuel else False
165:    if debug:
166:        for i, r in enumerate(REGIMES):
167:            out[f"score_{r}"] = scores[:, i]
168:        out["fuel_mod"] = fuel_mod
169:        out["fuel_votes"] = fuel_votes
170:    return out
171:
172:
173:def to_records(res: pd.DataFrame) -> list:
174:    """Output contract: [{regime, confidence, timestamp}] for classified candles only."""
175:    ok = res["regime"].notna()
176:    return [{"regime": r, "confidence": float(c), "timestamp": ts.isoformat()}
177:            for ts, r, c in zip(res.index[ok], res.loc[ok, "regime"], res.loc[ok, "confidence"])]

