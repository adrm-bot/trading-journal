101:def headline(symbol: str, write=True):
102:    df, excluded, _ = load(symbol)
103:    feat, f, b2, b1 = tracks(df)
104:    idx = trim(f).index
105:    exc = full_excluded(excluded, trim(f))
106:    F, B2, B1 = trim(f)["regime"], trim(b2)["regime"], trim(b1)
107:
108:    fvb = pair_stats(B1, F, idx, exc)
109:    avb = pair_stats(B1, B2, idx, exc)
110:
111:    out = {"symbol": symbol, "n_candles": len(idx),
112:           "span": [str(idx[0]), str(idx[-1])],
113:           "F_vs_B1": {}, "B2_vs_B1": {}, "OI_marginal": {}}
114:    # point estimate = OBSERVED raw median difference (the same estimand the null stage
115:    # tests); the paired month bootstrap contributes the CI only (its own median is kept as
116:    # a diagnostic — mixing the two up would report a smoothed number against a raw null)
117:    for cls in CLASSES:
118:        out["F_vs_B1"][cls] = _cls_row(fvb[cls])
119:        out["B2_vs_B1"][cls] = _cls_row(avb[cls])
120:        obs_diff = float(np.median(fvb[cls]["leads"]) - np.median(avb[cls]["leads"])) \
121:            if len(fvb[cls]["leads"]) and len(avb[cls]["leads"]) else np.nan
122:        boot_med, lo, hi = leadlag.paired_month_bootstrap_diff(
123:            fvb[cls]["leads"], fvb[cls]["months"], avb[cls]["leads"], avb[cls]["months"])
124:        out["OI_marginal"][cls] = {"median_diff": obs_diff, "ci95": [lo, hi],
125:                                   "boot_median_diff": boot_med}
126:    # pooled enter-TREND (both directions) — the pre-registered primary endpoint uses this
127:    lf = np.concatenate([fvb[c]["leads"] for c in CLASSES])
128:    mf = np.concatenate([fvb[c]["months"] for c in CLASSES])
129:    lb = np.concatenate([avb[c]["leads"] for c in CLASSES])
130:    mb = np.concatenate([avb[c]["months"] for c in CLASSES])
131:    boot_med, lo, hi = leadlag.paired_month_bootstrap_diff(lf, mf, lb, mb)
132:    obs_pooled = float(np.median(lf) - np.median(lb)) if len(lf) and len(lb) else np.nan
133:    out["OI_marginal"]["enter_pooled"] = {"median_diff": obs_pooled, "ci95": [lo, hi],
134:                                          "boot_median_diff": boot_med,
135:                                          "F_median": float(np.median(lf)) if len(lf) else np.nan,
136:                                          "B2_median": float(np.median(lb)) if len(lb) else np.nan}
137:    out["churn"] = {"B1": round(fvb["churn_base"], 3), "F": round(fvb["churn_fused"], 3),
138:                    "B2": round(avb["churn_fused"], 3), "F_flap": round(fvb["flap_fused"], 3)}
139:
140:    # era decomposition (sign consistency): median F-vs-B1 lead per era, per class pooled
141:    eras = {}
142:    for name, a, b in ERAS:
143:        t0 = pd.Timestamp(a, tz="UTC")
144:        t1 = pd.Timestamp(b, tz="UTC") + pd.Timedelta(days=1)
145:        leads = []
146:        for cls in CLASSES:
147:            st = fvb[cls]
148:            sel = [(idx[s] >= t0) and (idx[s] < t1) for s in st["pair_base_starts"]]
149:            leads += list(st["leads"][np.array(sel, dtype=bool)]) if st["n_matched"] else []
150:        eras[name] = {"n": len(leads),
151:                      "median": float(np.median(leads)) if leads else np.nan}
152:    out["eras"] = eras
153:    signs = [e["median"] for e in eras.values() if e["n"] >= 10]
154:    out["era_sign_consistency"] = f"{sum(1 for s in signs if s > 0)}/{len(signs)} eras positive"
155:
156:    # descriptives: occupancy + dwell per state (the current-state deliverable's health check)
157:    occ = F.value_counts(normalize=True).round(4).to_dict()
158:    sup = leadlag.to_super(F)
159:    dwell = {}
160:    for state in classifier.REGIMES:
161:        runs = []
162:        cnt = 0
163:        for x in F:
164:            if (not pd.isna(x)) and x == state:
165:                cnt += 1
166:            elif cnt:
167:                runs.append(cnt)
168:                cnt = 0
169:        if cnt:
170:            runs.append(cnt)
171:        dwell[state] = {"n_runs": len(runs), "median_bars": float(np.median(runs)) if runs else 0}
172:    out["descriptives"] = {"occupancy": occ, "dwell": dwell,
173:                           "native_churn_F": round(float((F != F.shift()).sum() / len(F) * 100), 3)}
174:
175:    # sensitivity: fuel params (k x deadzone) -> pooled enter median of F vs B1
176:    sens = {}
177:    for k in (4, 8, 16):
178:        for dq in (0.10, 0.25):
179:            fp2 = FeatureParams(oi_lookback=k, dead_q=dq)
180:            _, f2, _, _ = tracks(df, fp=fp2)
181:            p2 = pair_stats(B1, trim(f2)["regime"], idx, exc)
182:            leads2 = np.concatenate([p2[c]["leads"] for c in CLASSES])
183:            sens[f"k{k}_dz{dq}"] = {"median": float(np.median(leads2)) if len(leads2) else np.nan,
184:                                    "n": int(len(leads2)),
185:                                    "churn_F": round(p2["churn_fused"], 3)}
186:    out["sensitivity_fuel"] = sens
187:    # sensitivity: matching params (min_len x overlap)
188:    sens_m = {}
189:    for d in (1, 4, 8):
190:        for ovl in (0.01, 0.25, 0.5):
191:            mp = MatchParams(min_len=d, min_overlap=ovl)
192:            p2 = pair_stats(B1, F, idx, exc, mp)
193:            leads2 = np.concatenate([p2[c]["leads"] for c in CLASSES])
194:            sens_m[f"d{d}_ov{ovl}"] = {"median": float(np.median(leads2)) if len(leads2) else np.nan,
195:                                       "n": int(len(leads2))}
196:    out["sensitivity_match"] = sens_m
197:
198:    # OI publication-latency robustness: fuel from oi lagged one 5m snapshot
199:    if "oi_lag1" in df.columns:
200:        _, f_lag, _, _ = tracks(df, oi_col="oi_lag1")
201:        pl = pair_stats(B1, trim(f_lag)["regime"], idx, exc)
202:        leads_l = np.concatenate([pl[c]["leads"] for c in CLASSES])
203:        med_diff_l, lo_l, hi_l = leadlag.paired_month_bootstrap_diff(
204:            leads_l, np.concatenate([pl[c]["months"] for c in CLASSES]), lb, mb)
205:        out["oi_lag1_robustness"] = {
206:            "F_median": float(np.median(leads_l)) if len(leads_l) else np.nan,
207:            "OI_marginal_median_diff": med_diff_l, "ci95": [lo_l, hi_l]}
208:
209:    if write:
210:        RESULTS.mkdir(exist_ok=True)
211:        (RESULTS / f"{symbol}_headline.json").write_text(json.dumps(out, indent=1, default=str))
212:    return out
