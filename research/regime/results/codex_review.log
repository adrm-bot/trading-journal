67:def _epoch_to_utc(series: pd.Series) -> pd.Series:
68:    """Epoch ints of unknown unit (ms until 2025-01, us after) -> tz-aware UTC (ns)."""
69:    v = series.astype("int64")
70:    med = float(v.median())
71:    if med > 1e14:  # microseconds
72:        v = v // 1000
73:    return _as_ns(pd.to_datetime(v, unit="ms", utc=True))
