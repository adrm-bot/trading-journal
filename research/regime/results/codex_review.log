40:def fetch_dvol(currency="BTC") -> pd.DataFrame:
41:    cache = HERE / "data" / f"DVOL_{currency}.parquet"
42:    if cache.exists():
43:        return pd.read_parquet(cache)
44:    url = "https://www.deribit.com/api/v2/public/get_volatility_index_data"
45:    start = int(dt.datetime(2021, 3, 24, tzinfo=dt.timezone.utc).timestamp() * 1000)
46:    now = int(dt.datetime.now(dt.timezone.utc).timestamp() * 1000)
47:    rows = []
48:    cur = start
49:    step = 1000 * 3600 * 1000  # 1000 hourly candles per call
50:    while cur < now:
51:        r = requests.get(url, params=dict(currency=currency, resolution=3600,
52:                                          start_timestamp=cur,
53:                                          end_timestamp=min(cur + step, now)), timeout=30)
54:        r.raise_for_status()
55:        rows += r.json()["result"]["data"]
56:        cur += step
57:    df = pd.DataFrame(rows, columns=["ts_start", "open", "high", "low", "dvol"])
58:    df = df.drop_duplicates("ts_start").sort_values("ts_start")
59:    # candle close value is KNOWN only at candle end: availability = start + 1h
60:    df["known_ts"] = pd.to_datetime(df["ts_start"].astype("int64"), unit="ms", utc=True) \
61:        + pd.Timedelta(hours=1)
62:    df["known_ts"] = df["known_ts"].astype("datetime64[ns, UTC]")
63:    out = df[["known_ts", "dvol"]].reset_index(drop=True)
64:    out.to_parquet(cache)
65:    return out
