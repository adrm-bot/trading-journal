68:
69:def _labels(arr) -> np.ndarray:
70:    a = arr.to_numpy(object)
71:    return np.array(["__NA__" if pd.isna(x) else str(x) for x in a], dtype=object)
72:
73:
74:def _mismatches(full, sub, upto):
75:    """Compare (f, b2, b1) tuples on rows <= upto; return list of mismatch descriptions."""
76:    out = []
77:    for name, a, b in [("F", full[0], sub[0]), ("B2", full[1], sub[1])]:
78:        ai, bi = a.loc[a.index <= upto], b.loc[b.index <= upto]
79:        if not ai.index.equals(bi.index):
80:            out.append(f"{name}: index mismatch")
81:            continue
82:        neq = _labels(ai["regime"]) != _labels(bi["regime"])
83:        if neq.any():
84:            out.append(f"{name}: {neq.sum()} label mismatches, first at {ai.index[neq][0]}")
85:        ca = ai["confidence"].to_numpy(float)
86:        cb = bi["confidence"].to_numpy(float)
87:        cneq = ~(np.isclose(ca, cb, atol=1e-12) | (np.isnan(ca) & np.isnan(cb)))
88:        if cneq.any():
89:            out.append(f"{name}: {cneq.sum()} confidence mismatches, first at {ai.index[cneq][0]}")
90:    neq = _labels(full[2].loc[full[2].index <= upto]) != _labels(sub[2].loc[sub[2].index <= upto])
91:    if neq.any():
92:        out.append(f"B1: {neq.sum()} label mismatches")
93:    return out
