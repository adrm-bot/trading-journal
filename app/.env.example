# app/.env (로컬) 또는 배포 플랫폼 환경변수. .env 는 git 미추적.
# === 로컬 개발 기본값 ===
APP_ENV=development          # 배포: production
DEV_MODE=true                # 배포: false (필수! true면 무인증 dev-login이 열림)
LOOKBACK_DAYS=30

# 암호화/세션 (둘 다 필수, 강한 랜덤)
APP_SECRET_KEY=              # `python -m app.genkey` 로 생성 (Fernet 키)
SESSION_SECRET=              # `python -c "import secrets;print(secrets.token_hex(32))"`

# DB 경로 — 로컬은 비워두면 app/data.db. 배포는 영속 볼륨 경로(예: /var/data/data.db)
APP_DB_PATH=

# === 배포(프로덕션)용 ===
# Google OAuth — Google Cloud Console > OAuth 2.0 Client (웹). 승인 redirect URI에 아래 콜백 등록.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=          # 예: https://<당신-앱>.onrender.com/auth/callback
