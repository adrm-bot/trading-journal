//@version=6
// REGIME v1.4 — 5-상태 레짐 분류기 (research/regime 파이썬 구현의 차트 포팅)
// v1.4: MTF 3분할 밴드(위 하위TF·중간 현재·아래 상위TF) · 마커 '성김' 모드 · 5m 창 캡
//        · TV 데이터 패리티 검증(MCP: TV 봉 = Binance REST 봉, Δ=0)
//
// 산출물 계약: 캔들마다 {레짐, confidence} 만. 셋업/전환감시 행은 표시 레이어(분류기 불변).
// 5상태(색): 🟢상승추세 / 🔴하락추세 / 🔵수렴(돌파대기) / ⚪박스권 / 🟠난장판(관망)
//
// v1.3 기본기 강화:
//   - 창 길이 벽시계 자동 스케일링(30일) — 어떤 TF 차트에서도 동일 의미 (기존: 15m 고정 봉수)
//   - 상위 방향 1H·4H·1D 통합 행 / 눌림목 셋업 행(ADX_Gunner 규칙) / 전환 감시 행(엄격)
//   - 테이블 배경(다크 차트 가독성) / 확신선 레짐 색 / 한·영 토글
//
// 검증된 사실(BTC 15m 2022→2026 + ETH/SOL/XRP 복제, 외부감사 Codex 반영):
//   - 라벨 = 시장 '성격'(변동성 구조) 기술. 방향 예측력 없음 — 방향·레버리지는 상위 TF.
//   - 눌림목 서식지(H1 추세+15m 수렴/박스) 자체는 통계 엣지 없음(사전등록 검증, 중앙값 약음)
//     → 셋업 행은 '후보+트리거' 감지일 뿐, 엣지는 트리거·손절 구조가 만들어야 함.
//   - OI 융합의 조기화는 널 대비 우월 증거 없음(p=1.0). confirm_bars=1 = 리드 희생 0에 churn −26%.
// 알림은 반드시 "Once Per Bar Close"로 (확정 봉에서만 갱신 — 리페인트 방지).
indicator("REGIME v1 — 5-state regime [Gunner]", overlay = false, max_bars_back = 5000, max_labels_count = 100)

// ── 언어 ─────────────────────────────────────────────────────────────────────
lang = input.string("한국어", "언어 / Language", options = ["한국어", "English"], group = "표시 / Display")
L(string k, string e) => lang == "한국어" ? k : e

// ── 동결 파라미터 (봉수는 벽시계 자동 스케일) ────────────────────────────────
adxLen   = input.int(14,  "ADX/DI 기간",       group = "동결 파라미터(리서치)")
adxLo    = input.float(20, "ADX 하한",          group = "동결 파라미터(리서치)")
adxScale = input.float(15, "ADX 스케일",        group = "동결 파라미터(리서치)")
emaFLen  = input.int(20,  "EMA fast",           group = "동결 파라미터(리서치)")
emaSLen  = input.int(50,  "EMA slow",           group = "동결 파라미터(리서치)")
bbLen    = input.int(20,  "BB 기간",            group = "동결 파라미터(리서치)")
bbK      = input.float(2.0, "BB 표준편차",      group = "동결 파라미터(리서치)")
deadQ    = input.int(25,  "데드존 분위(%)",     group = "동결 파라미터(리서치)")
wDir     = 0.5
wVol     = 0.3
wFuel    = 0.2
nearTie  = 0.02
minDwell    = input.int(0, "min_dwell(봉)",     group = "hysteresis (기본 OFF)")
confirmBars = input.int(0, "confirm_bars(봉)",  group = "hysteresis (기본 OFF)", tooltip = "1로 올리면 리드 희생 없이 잦은 전환 −26% (리서치 스윕)")

// 벽시계 스케일링: 리서치 동결값(15m 기준 30일=2880봉, ΔOI 2시간=8봉)을 TF 무관 유지
int tfSec = timeframe.in_seconds()
int barsPerDay = math.max(1, math.round(86400.0 / tfSec))
// 30일 분위수 창. 상한 4000봉 = max_bars_back 예산(5m에선 ~14일로 캡 — 문서화된 근사)
int qWin = math.min(4000, math.max(200, 30 * barsPerDay))
int kOI  = math.max(1, math.round(7200.0 / tfSec))   // ΔOI lookback = 2시간
int dipLB = math.max(8, math.round(28800.0 / tfSec)) // '최근 하락 경유' = 8시간

// ── 표시 옵션 ────────────────────────────────────────────────────────────────
posStr   = input.string("우상단", "테이블 위치", options = ["좌상단", "중앙상단", "우상단", "좌중앙", "중앙", "우중앙", "좌하단", "중앙하단", "우하단"], group = "표시 / Display")
showMain = input.bool(true, "메인 차트 리본", group = "표시 / Display", tooltip = "가격 차트 배경 색칠 on/off — 다른 지표 배경과 겹쳐 어지러우면 끄기")
lblDensity = input.string("성김", "전환 마커", options = ["전부", "성김", "끄기"], group = "표시 / Display", tooltip = "성김(기본): 1봉 생존한 전환만 + 최소 8봉 간격 — 빠른 TF에서 마커 홍수 방지")
showBands = input.bool(true, "MTF 밴드(위 하위TF · 중간 현재 · 아래 상위TF)", group = "표시 / Display", tooltip = "TF 사다리: 5m→15m→1h→4h→12h→1D. 밴드는 연료축 없는 2축 근사(연구상 연료 기여 p=1.0이라 근사 정당) · 무FSM 순간 판정 · 하위TF는 TV security 특성상 참고용")
tblSize  = input.string("작게", "테이블 글자", options = ["아주작게", "작게", "보통", "크게"], group = "표시 / Display")

// ── 피처 (전부 인과: 현재 봉 종가까지만) ────────────────────────────────────
[diP, diM, adx] = ta.dmi(adxLen, adxLen)
atr  = ta.rma(ta.tr(true), adxLen)
m    = (ta.ema(close, emaFLen) - ta.ema(close, emaSLen)) / atr
bbw  = 2 * bbK * ta.stdev(close, bbLen) / ta.sma(close, bbLen)
atrp = atr / close
volPct = (ta.percentrank(bbw, qWin) + ta.percentrank(atrp, qWin)) / 200.0  // 과거 전용

// OI 피드: 현재 심볼 → 없으면 무기한(.P) 폴백 (현물 차트 대응)
string oiSym  = syminfo.prefix + ":" + syminfo.ticker + "_OI"
string oiSymP = syminfo.prefix + ":" + syminfo.ticker + ".P_OI"
oi1 = request.security(oiSym, timeframe.period, close, ignore_invalid_symbol = true)
oi2 = request.security(oiSymP, timeframe.period, close, ignore_invalid_symbol = true)
oiClose = na(oi1) ? oi2 : oi1
bool oiFromPerp = na(oi1) and not na(oi2)
oiOk    = not na(oiClose) and not na(oiClose[kOI])
doi     = oiOk ? (oiClose - oiClose[kOI]) / oiClose[kOI] : na
dpr     = (close - close[kOI]) / close[kOI]
dzDoi   = ta.percentile_nearest_rank(math.abs(doi[1]), qWin, deadQ)   // 과거 전용(1봉 시프트)
dzDpr   = ta.percentile_nearest_rank(math.abs(dpr[1]), qWin, deadQ)
quadOn = oiOk and not na(dzDoi) and not na(dzDpr) and math.abs(doi) >= dzDoi and math.abs(dpr) >= dzDpr
quad   = not quadOn ? 0 : doi > 0 and dpr > 0 ? 1 : doi > 0 and dpr < 0 ? 2 : doi < 0 and dpr > 0 ? 3 : doi < 0 and dpr < 0 ? 4 : 0

// ── 축 점수 → 5상태 ─────────────────────────────────────────────────────────
tanhPos(float x) =>
    float xc = math.min(x, 20.0)
    float e2 = math.exp(2.0 * xc)
    (e2 - 1.0) / (e2 + 1.0)

a      = math.max(0.0, math.min(1.0, (adx - adxLo) / adxScale))
tRaw   = a * tanhPos(math.abs(m))
agreeD = math.sign(diP - diM) == math.sign(m)
T      = agreeD ? tRaw : tRaw * 0.5
dirUp   = m > 0 ? T : 0.0
dirDn   = m < 0 ? T : 0.0
dirRest = (1.0 - dirUp - dirDn) / 3.0
muL = math.max(0.0, math.min(1.0, (0.25 - volPct) / 0.10))
muH = math.max(0.0, math.min(1.0, (volPct - 0.75) / 0.10))
muM = math.max(0.0, 1.0 - muL - muH)

fuelVotes = quad == 1 or quad == 2
wPresent  = wDir + wVol + (fuelVotes ? wFuel : 0.0)
sUP = (wDir * dirUp   + (quad == 1 ? wFuel : 0.0)) / wPresent
sDN = (wDir * dirDn   + (quad == 2 ? wFuel : 0.0)) / wPresent
sSQ = (wDir * dirRest + wVol * muL) / wPresent
sRA = (wDir * dirRest + wVol * muM) / wPresent
sCH = (wDir * dirRest + wVol * muH) / wPresent

// argmax + 니어타이 현직 우선 + 온라인 FSM(확정 봉 스탬프, 역서명 없음)
var int cur = -1
var int pending = -1
var int pendCnt = 0
var int sinceSwitch = 100000
score(i) => i == 0 ? sUP : i == 1 ? sDN : i == 2 ? sSQ : i == 3 ? sRA : sCH
int best = 0
float bestV = sUP
if sDN > bestV
    best := 1
    bestV := sDN
if sSQ > bestV
    best := 2
    bestV := sSQ
if sRA > bestV
    best := 3
    bestV := sRA
if sCH > bestV
    best := 4
    bestV := sCH
bool ready = not na(volPct) and not na(m) and not na(adx)
if ready and barstate.isconfirmed
    int cand = cur >= 0 and score(cur) >= bestV - nearTie ? cur : best
    if cur < 0
        cur := cand
        sinceSwitch := 0
    else if cand != cur
        pendCnt := cand == pending ? pendCnt + 1 : 1
        pending := cand
        if pendCnt >= confirmBars + 1 and sinceSwitch >= minDwell
            cur := cand
            sinceSwitch := 0
            pending := -1
            pendCnt := 0
    else
        pending := -1
        pendCnt := 0
    sinceSwitch += 1
else if not ready and barstate.isconfirmed
    cur := -1
    pending := -1
    pendCnt := 0
    sinceSwitch := 100000

// confidence = 합의 × 마진 × 수정자, [0,1] 클램프
float agreement = ready and cur >= 0 ? score(cur) : na
float runnerUp = 0.0
int runnerIdx = -1
if ready and cur >= 0
    for i = 0 to 4
        if i != cur and score(i) > runnerUp
            runnerUp := score(i)
            runnerIdx := i
bool dzDefined = oiOk and not na(dzDoi) and not na(dzDpr)
float fuelMod = quad == 3 or quad == 4 ? 0.85 : dzDefined and quad == 0 ? 0.95 : 1.0
float conf = na(agreement) ? na : math.max(0.0, math.min(1.0, agreement * (1.0 - 0.5 * (agreement > 1e-12 ? runnerUp / agreement : 2.0)) * fuelMod * (dzDefined ? 1.0 : 0.8)))

// 확신 급락(collapse) — 실시간 봉은 직전 확정값 사용(리페인트 없음). 셋업/전환감시가 공용
float confShow = barstate.isrealtime ? conf[1] : conf
confQ20 = ta.percentile_nearest_rank(conf[1], qWin, 20)
float confQ20Show = barstate.isrealtime ? confQ20[1] : confQ20
collapse = not na(confShow) and not na(confShow[1]) and not na(confQ20Show) and not na(confQ20Show[1]) and confShow < confQ20Show and confShow[1] < confQ20Show[1]
int sinceCollapse = ta.barssince(collapse)
bool recentClps = not na(sinceCollapse) and sinceCollapse <= 4

// ── 상태 이름·색 ─────────────────────────────────────────────────────────────
color stCol = cur == 0 ? color.green : cur == 1 ? color.red : cur == 2 ? color.blue : cur == 3 ? color.gray : color.orange
nameOf(i) => i == 0 ? L("상승추세", "Uptrend") : i == 1 ? L("하락추세", "Downtrend") : i == 2 ? L("수렴(돌파대기)", "Squeeze") : i == 3 ? L("박스권", "Range") : i == 4 ? L("난장판(관망)", "Chop") : L("준비 중", "Warming up")
emojiOf(i) => i == 0 ? "🟢" : i == 1 ? "🔴" : i == 2 ? "🔵" : i == 3 ? "⚪" : i == 4 ? "🟠" : "…"

// 메인 차트 리본 (진할수록 확신 높음). 레짐 패널 색은 showBands(MTF 3등분 밴드)가 담당
int transp = na(conf) ? 90 : int(90 - 70 * math.min(conf / 0.6, 1.0))
bgcolor(ready and showMain ? color.new(stCol, transp) : na, title = "regime ribbon (main)", force_overlay = true)

// ── 상위 방향 1H·4H·1D (단순 ADX/DI, 확정 봉만 — 리페인트 방지) ─────────────
f_htfDir() =>
    [dp, dm, ax] = ta.dmi(adxLen, adxLen)
    [dp[1], dm[1], ax[1]]
[dp60, dm60, ax60]  = request.security(syminfo.tickerid, "60",  f_htfDir())
[dp240, dm240, ax240] = request.security(syminfo.tickerid, "240", f_htfDir())
[dpD, dmD, axD]     = request.security(syminfo.tickerid, "D",   f_htfDir())
dirIcon(dp, dm, ax) => na(ax) ? "…" : ax >= 25 and dp > dm ? "🟢" : ax >= 25 and dm > dp ? "🔴" : "⚪"
string htfRow = "1H " + dirIcon(dp60, dm60, ax60) + "  4H " + dirIcon(dp240, dm240, ax240) + "  1D " + dirIcon(dpD, dmD, axD)

// ── 눌림목 셋업 감지 (ADX_Gunner 규칙 이식 — 표시 레이어, 분류기 불변) ──────
// HTF 스윗스팟: 셋업 기준 상위TF = 한 단계 위 (15m→1H, 1H→4H, 4H이상→1D)
float hAx = tfSec < 3600 ? ax60 : tfSec < 14400 ? ax240 : axD
float hDp = tfSec < 3600 ? dp60 : tfSec < 14400 ? dp240 : dpD
float hDm = tfSec < 3600 ? dm60 : tfSec < 14400 ? dm240 : dmD
string hTfName = tfSec < 3600 ? "1H" : tfSec < 14400 ? "4H" : "1D"
bool hSweetUp = not na(hAx) and hAx >= 20 and hAx <= 40 and hDp > hDm
bool hSweetDn = not na(hAx) and hAx >= 20 and hAx <= 40 and hDm > hDp
bool hMature  = not na(hAx) and hAx > 40
// EMA 정배열(보조 확인)
e100 = ta.ema(close, 100)
e200 = ta.ema(close, 200)
e20  = ta.ema(close, emaFLen)
e50  = ta.ema(close, emaSLen)
bool stackUp = e20 > e50 and e50 > e100 and e100 > e200
bool stackDn = e20 < e50 and e50 < e100 and e100 < e200
// DI 재가속 트리거 (2봉 확정, ADX_Gunner식 단순판)
float spread = diP - diM
float sprAbs = math.abs(spread)
bool reUp = spread > 0 and sprAbs > sprAbs[1] and sprAbs - sprAbs[2] > 0
bool reDn = spread < 0 and sprAbs > sprAbs[1] and sprAbs - sprAbs[2] > 0
// 최근 반대 레그 경유(8h) — "하락 후 수렴" 요소 (barssince는 최초 발생 전 na → 가드)
int bsDn = ta.barssince(cur == 1)
int bsUp = ta.barssince(cur == 0)
bool dippedDn = not na(bsDn) and bsDn <= dipLB
bool dippedUp = not na(bsUp) and bsUp <= dipLB
bool inPB = cur == 2 or cur == 3   // 수렴/박스권
string setupTxt = na
if hMature
    setupTxt := "⚠ " + hTfName + " " + L("과열(ADX>40) — 신규 진입 리스크↑", "mature (ADX>40) — new entries risky")
else if hSweetUp and inPB
    // 검증(continuation_study): 횡보 중 확신급락은 재점화가 아니라 추세 '반대' 기울어짐(BTC/ETH 4h ↑44%)
    string warnL = recentClps ? " · ⚠" + L("확신급락(역압력)", "collapse(counter-pressure)") : ""
    string ext = (stackUp ? " · " + L("EMA정배열", "EMA stacked") : "") + (dippedDn ? " · " + L("하락경유", "post-dip") : "") + warnL
    setupTxt := (reUp ? "⚡ " + L("눌림목 롱 — DI 재가속", "Pullback LONG — DI re-accel") : "🟡 " + L("눌림목 롱 후보 (트리거 대기)", "Pullback long candidate (await trigger)")) + ext
else if hSweetDn and inPB
    string warnS = recentClps ? " · ⚠" + L("확신급락(역압력)", "collapse(counter-pressure)") : ""
    string ext2 = (stackDn ? " · " + L("EMA역배열", "EMA stacked dn") : "") + (dippedUp ? " · " + L("반등경유", "post-pop") : "") + warnS
    setupTxt := (reDn ? "⚡ " + L("되돌림 숏 — DI 재가속", "Pullback SHORT — DI re-accel") : "🟡 " + L("되돌림 숏 후보 (트리거 대기)", "Pullback short candidate (await trigger)")) + ext2
else
    setupTxt := L("없음", "none")
bool setupTrig = (hSweetUp and inPB and reUp) or (hSweetDn and inPB and reDn)

// ── 전환 감시 (엄격: 2조건 동시 — 현직 열세 지속 + 최근 확신 급락) ──────────
var int negRun = 0
var int watchNext = -1
if barstate.isconfirmed
    bool losing = ready and cur >= 0 and runnerUp > score(cur)
    negRun := losing ? negRun + 1 : 0
    watchNext := losing ? runnerIdx : -1
bool watchOn = negRun >= 2 and not na(sinceCollapse) and sinceCollapse <= 8
string watchTxt = watchOn ? "⚠ " + L("표 이동 중 → 2위: ", "votes shifting → #2: ") + emojiOf(watchNext) + " " + nameOf(watchNext) + " (" + str.tostring(negRun) + L("봉째", " bars") + ")" : collapse ? "⚠ " + L("확신 급락 — 전환 가능성, 사이즈 축소", "confidence collapse — possible shift, size down") : L("안정 — 현 상태 우세", "stable — incumbent leads")

// 전환 마커 — '성김'(기본): 1봉 생존한 전환만 + 최소 8봉 간격 (빠른 TF 마커 홍수 방지)
var int lastLblBar = -100000
bool transRaw = barstate.isconfirmed and cur >= 0 and cur != cur[1]
bool transSurvived = barstate.isconfirmed and cur >= 0 and cur == cur[1] and cur[1] != cur[2]
if lblDensity == "전부" and transRaw
    label.new(bar_index, na, emojiOf(cur) + " " + nameOf(cur), yloc = yloc.abovebar, style = label.style_label_down, color = color.new(stCol, 25), textcolor = color.white, size = size.small, force_overlay = true)
if lblDensity == "성김" and transSurvived and bar_index - lastLblBar >= 8
    label.new(bar_index - 1, na, emojiOf(cur) + " " + nameOf(cur), yloc = yloc.abovebar, style = label.style_label_down, color = color.new(stCol, 25), textcolor = color.white, size = size.small, force_overlay = true)
    lastLblBar := bar_index

// ── MTF 3분할 밴드: 위=하위TF · 중간=현재TF · 아래=상위TF (사다리 5m→15m→1h→4h→12h→1D) ──
// 밴드용 2축 근사 레짐 (연료축 제외 — request.security 중첩 금지 + 연구상 연료 기여 p=1.0)
f_regime2(int qw) =>
    [dp2, dm2, ax2] = ta.dmi(adxLen, adxLen)
    float atr2 = ta.rma(ta.tr(true), adxLen)
    float mm = (ta.ema(close, emaFLen) - ta.ema(close, emaSLen)) / atr2
    float vp = (ta.percentrank(2 * bbK * ta.stdev(close, bbLen) / ta.sma(close, bbLen), qw) + ta.percentrank(atr2 / close, qw)) / 200.0
    float aa = math.max(0.0, math.min(1.0, (ax2 - adxLo) / adxScale))
    float t0 = aa * tanhPos(math.abs(mm))
    float tt = math.sign(dp2 - dm2) == math.sign(mm) ? t0 : t0 * 0.5
    float up2 = mm > 0 ? tt : 0.0
    float dn2 = mm < 0 ? tt : 0.0
    float rs = (1.0 - up2 - dn2) / 3.0
    float mL2 = math.max(0.0, math.min(1.0, (0.25 - vp) / 0.10))
    float mH2 = math.max(0.0, math.min(1.0, (vp - 0.75) / 0.10))
    float mM2 = math.max(0.0, 1.0 - mL2 - mH2)
    float c0 = wDir * up2 / 0.8
    float c1 = wDir * dn2 / 0.8
    float c2 = (wDir * rs + wVol * mL2) / 0.8
    float c3 = (wDir * rs + wVol * mM2) / 0.8
    float c4 = (wDir * rs + wVol * mH2) / 0.8
    int b = 0
    float bv = c0
    if c1 > bv
        b := 1
        bv := c1
    if c2 > bv
        b := 2
        bv := c2
    if c3 > bv
        b := 3
        bv := c3
    if c4 > bv
        b := 4
        bv := c4
    float agree2 = bv
    float run2 = 0.0
    for i2 = 0 to 4
        float si = i2 == 0 ? c0 : i2 == 1 ? c1 : i2 == 2 ? c2 : i2 == 3 ? c3 : c4
        if i2 != b and si > run2
            run2 := si
    float cf2 = math.max(0.0, math.min(1.0, agree2 * (1.0 - 0.5 * (agree2 > 1e-12 ? run2 / agree2 : 2.0))))
    int bOut = na(vp) or na(mm) or na(ax2) ? -1 : b
    float cOut = na(vp) or na(mm) or na(ax2) ? na : cf2
    [bOut[1], cOut[1]]  // 확정 봉만 (비리페인트) — [상태, 확신]

string tfLow  = tfSec <= 300 ? "5" : tfSec <= 900 ? "5" : tfSec <= 3600 ? "15" : tfSec <= 14400 ? "60" : tfSec <= 43200 ? "240" : tfSec <= 86400 ? "720" : "D"
string tfHigh = tfSec < 900 ? "15" : tfSec < 3600 ? "60" : tfSec < 14400 ? "240" : tfSec < 43200 ? "720" : tfSec < 86400 ? "D" : "W"
bool hasLow = tfSec > 300  // 5m가 사다리 최하단
qwFor(string tf) =>
    tf == "5" ? 4000 : tf == "15" ? 2880 : tf == "60" ? 720 : 200
[stLow, cfLow]   = request.security(syminfo.tickerid, tfLow,  f_regime2(qwFor(tfLow)))
[stHigh, cfHigh] = request.security(syminfo.tickerid, tfHigh, f_regime2(qwFor(tfHigh)))
f_stateCol(int i) => na(i) ? color.new(color.gray, 80) : i == 0 ? color.green : i == 1 ? color.red : i == 2 ? color.blue : i == 3 ? color.gray : i == 4 ? color.orange : color.new(color.gray, 80)
// 확신 → 불투명도 그라데이션 (선이 위에서 읽히도록 밴드는 메인 리본보다 연하게)
f_bandT(float cf) => na(cf) ? 88 : int(86 - 52 * math.min(cf / 0.6, 1.0))
color colLow  = showBands and hasLow and not na(stLow) ? color.new(f_stateCol(stLow), f_bandT(cfLow)) : na
color colCur  = showBands and ready and cur >= 0 ? color.new(stCol, f_bandT(conf)) : na
color colHigh = showBands and not na(stHigh) ? color.new(f_stateCol(stHigh), f_bandT(cfHigh)) : na
// 3등분이 패널 전체를 채우고, 확신선이 그 위에 겹쳐 그려짐 (위=하위TF · 중간=현재 · 아래=상위TF)
pB0 = plot(showBands ? 1.0 : na,    "밴드경계1", color = color.new(color.gray, 100), editable = false)
pB1 = plot(showBands ? 0.6667 : na, "밴드경계2", color = color.new(#000000, 55), editable = false, linewidth = 1)
pB2 = plot(showBands ? 0.3333 : na, "밴드경계3", color = color.new(#000000, 55), editable = false, linewidth = 1)
pB3 = plot(showBands ? 0.0 : na,    "밴드경계4", color = color.new(color.gray, 100), editable = false)
fill(pB0, pB1, color = colLow,  title = "하위TF 레짐 밴드")
fill(pB1, pB2, color = colCur,  title = "현재TF 레짐 밴드")
fill(pB2, pB3, color = colHigh, title = "상위TF 레짐 밴드")
tfName(string tf) => tf == "5" ? "5m" : tf == "15" ? "15m" : tf == "60" ? "1h" : tf == "240" ? "4h" : tf == "720" ? "12h" : tf == "D" ? "1D" : tf
var label lbBands = na
if showBands and barstate.islast
    label.delete(lbBands)
    string lowTxt = hasLow ? tfName(tfLow) : "—"
    lbBands := label.new(bar_index + 1, 0.5, "▲ " + lowTxt + "\n■ " + tfName(timeframe.period) + "\n▼ " + tfName(tfHigh), style = label.style_label_left, color = color.new(#131722, 30), textcolor = color.new(#c8c8c8, 0), size = size.small, tooltip = L("밴드: 위=하위TF · 중간=현재TF · 아래=상위TF · 진할수록 그 TF 확신 높음 (2축 근사·무FSM·참고용)", "Bands: top=lower TF · mid=current · bottom=higher TF · darker = higher confidence (2-axis approx, no FSM)"))

// 확신선 — 밴드 위에 겹쳐 표시 (선 색 = 현재 레짐, 실시간 봉은 직전 확정값: 리페인트 없음)
plot(confShow, "confidence", color = ready and cur >= 0 ? stCol : color.gray, linewidth = 2)
plot(confQ20Show, "conf rolling q20", color = color.new(color.gray, 40), style = plot.style_line)
plotshape(collapse, "confidence collapse", style = shape.xcross, location = location.bottom, color = color.new(color.red, 0), size = size.tiny)

// ── 상태 테이블 (메인 차트, 배경 있는 가독 버전) ────────────────────────────
posOf(string s) =>
    s == "좌상단" ? position.top_left : s == "중앙상단" ? position.top_center : s == "우상단" ? position.top_right : s == "좌중앙" ? position.middle_left : s == "중앙" ? position.middle_center : s == "우중앙" ? position.middle_right : s == "좌하단" ? position.bottom_left : s == "중앙하단" ? position.bottom_center : position.bottom_right
txtSz = tblSize == "아주작게" ? size.tiny : tblSize == "작게" ? size.small : tblSize == "크게" ? size.large : size.normal
color BG  = color.new(#131722, 10)
color BG2 = color.new(#1e222d, 10)
color TXT = color.new(#e8e8e8, 0)

confPct = ta.percentrank(conf, qWin)
doTxt(i) => i == 0 ? L("눌림목 롱 (상위 방향 확인)", "Pullback long (check HTF)") : i == 1 ? L("되돌림 숏 (상위 방향 확인)", "Pullback short (check HTF)") : i == 2 ? L("돌파 '확인 후' 진입 · 레벨 알림", "Enter AFTER confirmed break") : i == 3 ? L("박스 상/하단 역매매 (거래량 확인)", "Fade range edges (volume)") : L("관망 · 사이즈 축소", "Stand aside · size down")
dontTxt(i) => i == 0 ? L("역추세 숏 · 물타기", "No counter-shorts · no averaging") : i == 1 ? L("역추세 롱 · 나이프 캐칭", "No counter-longs · no knife-catch") : i == 2 ? L("첫 돌파 추격 · 미리 방향 베팅", "No chasing 1st break · no pre-bet") : i == 3 ? L("추세추종 · 돌파 추격", "No trend-following · no breakouts") : L("방향 베팅 전부 · 복수 매매", "No directional bets · no revenge")

var table tb = table.new(posOf(posStr), 2, 10, border_width = 1, border_color = color.new(#000000, 60), force_overlay = true)
if barstate.islast
    string gradeTxt = na(confPct) ? L("계산 중…", "computing…") : (confPct >= 70 ? L("높음 ●●●", "High ●●●") : confPct >= 30 ? L("보통 ●●○", "Mid ●●○") : L("낮음 ●○○", "Low ●○○")) + "  (" + str.tostring(conf, "0.00") + ")"
    string dataTxt = dzDefined ? (oiFromPerp ? L("정상 (무기한 OI 폴백)", "OK (perp OI fallback)") : L("정상 (OI 포함)", "OK (with OI)")) : L("OI 준비/끊김 → 보수 모드", "OI warming/missing → conservative")
    string dwellTxt = cur >= 0 ? "  ·  " + str.tostring(sinceSwitch) + L("봉째", " bars") : ""
    // 지금 시장: 현재 TF + 상위 TF 레짐(밴드용 2축 근사) 두 줄
    int stH = na(stHigh) ? -1 : stHigh
    string htfRegTxt = L("상위 ", "HTF ") + tfName(tfHigh) + ": " + emojiOf(stH) + " " + nameOf(stH)
    table.cell(tb, 0, 0, L("지금 시장", "Market now"), text_size = txtSz, bgcolor = BG, text_color = TXT)
    table.cell(tb, 1, 0, emojiOf(cur) + " " + nameOf(cur) + dwellTxt + "\n" + htfRegTxt, text_color = color.white, bgcolor = cur >= 0 ? color.new(stCol, 20) : BG2, text_size = txtSz, tooltip = L("첫 줄=현재 TF(3축·FSM), 둘째 줄=한 단계 위 TF(2축 근사) — 방향·레버리지는 상위가 우선", "Line1 = current TF (3-axis, FSM), Line2 = one TF up (2-axis approx) — direction/leverage from HTF first"))
    table.cell(tb, 0, 1, L("판단 확신", "Confidence"), text_size = txtSz, bgcolor = BG, text_color = TXT)
    table.cell(tb, 1, 1, gradeTxt, text_size = txtSz, bgcolor = BG2, text_color = TXT, tooltip = L("최근 30일의 나 자신과 비교한 상대 등급", "Percentile vs its own last 30 days"))
    table.cell(tb, 0, 2, L("상위 방향", "HTF direction"), text_size = txtSz, bgcolor = BG, text_color = TXT)
    table.cell(tb, 1, 2, htfRow, text_size = txtSz, bgcolor = BG2, text_color = TXT, tooltip = L("단순 ADX25/DI 기준. 방향·레버리지 결정은 상위 TF 우선", "Simple ADX25/DI. Direction/leverage from HTF first"))
    table.cell(tb, 0, 3, L("셋업", "Setup"), text_size = txtSz, bgcolor = BG, text_color = TXT)
    table.cell(tb, 1, 3, setupTxt, text_size = txtSz, bgcolor = setupTrig ? color.new(color.teal, 40) : BG2, text_color = TXT, tooltip = L("서식지 자체는 통계 엣지 없음(연구 검증) — 트리거·손절 구조 필수. HTF 스윗스팟=ADX 20~40", "Habitat alone has NO edge (validated) — trigger & stop structure required. HTF sweet spot = ADX 20-40"))
    table.cell(tb, 0, 4, L("전환 감시", "Shift watch"), text_size = txtSz, bgcolor = BG, text_color = TXT)
    table.cell(tb, 1, 4, watchTxt, text_size = txtSz, bgcolor = watchOn or collapse ? color.new(color.red, 60) : BG2, text_color = TXT, tooltip = L("엄격 기준: 현직 점수 열세 2봉+ AND 최근 8봉 내 확신 급락 — 2위 상태는 예측이 아니라 현재 점수 순위", "Strict: incumbent losing 2+ bars AND recent collapse. #2 is current score rank, not a forecast"))
    table.cell(tb, 0, 5, L("지금 할 것", "Do now"), text_size = txtSz, bgcolor = BG, text_color = TXT)
    table.cell(tb, 1, 5, cur >= 0 ? doTxt(cur) : "…", text_size = txtSz, bgcolor = BG2, text_color = TXT)
    table.cell(tb, 0, 6, L("하지 말 것", "Avoid"), text_size = txtSz, bgcolor = BG, text_color = TXT)
    table.cell(tb, 1, 6, cur >= 0 ? dontTxt(cur) : "…", text_size = txtSz, bgcolor = BG2, text_color = color.new(color.red, 15))
    table.cell(tb, 0, 7, L("데이터", "Data"), text_size = txtSz, bgcolor = BG, text_color = TXT)
    table.cell(tb, 1, 7, dataTxt, text_size = txtSz, bgcolor = BG2, text_color = TXT)
    table.cell(tb, 0, 8, L("색 안내", "Legend"), text_size = size.tiny, bgcolor = BG, text_color = TXT)
    table.cell(tb, 1, 8, "🟢" + nameOf(0) + " 🔴" + nameOf(1) + " 🔵" + nameOf(2) + " ⚪" + nameOf(3) + " 🟠" + nameOf(4), text_size = size.tiny, bgcolor = BG2, text_color = color.new(#c8c8c8, 0))
    string quadTxt = not oiOk ? L("OI 없음/준비", "no OI") : not dzDefined ? L("데드존 계산 중…", "deadzone warming…") : quad == 1 ? "🟩 " + L("신규 롱 유입 — 연료(라벨 투표)", "new longs — fuel (votes)") : quad == 2 ? "🟥 " + L("신규 숏 유입 — 연료(라벨 투표)", "new shorts — fuel (votes)") : quad == 3 ? "↩ " + L("숏 커버 — 라벨 불변·확신 −15%", "short covering — conf −15%") : quad == 4 ? "↩ " + L("롱 청산 — 라벨 불변·확신 −15%", "long liquidation — conf −15%") : "— " + L("데드존(유의미한 ΔOI 없음)", "deadzone (no meaningful ΔOI)")
    table.cell(tb, 0, 9, L("OI 사분면", "OI quadrant"), text_size = txtSz, bgcolor = BG, text_color = TXT)
    table.cell(tb, 1, 9, quadTxt, text_size = txtSz, bgcolor = BG2, text_color = quad == 1 ? color.new(color.green, 10) : quad == 2 ? color.new(color.red, 10) : TXT, tooltip = L("ΔOI(2h)×Δ가격(2h): ↑↑신규롱 ↑↓신규숏(연료) · ↓↑숏커버 ↓↓롱청산(라벨 불변, 확신만 삭감 — 무기한에선 강한 연속 레그) · ≈0 데드존", "ΔOI(2h)×Δprice(2h): up-up new longs, up-down new shorts (fuel) · down legs trim confidence only · ~0 deadzone"))

alertcondition(ta.change(cur) != 0, "Regime change", "REGIME v1: 레짐 전환 / regime changed")
alertcondition(collapse, "Confidence collapse", "REGIME v1: 확신 급락 — 전환 가능성 / confidence collapse")
alertcondition(setupTrig, "Pullback trigger", "REGIME v1: 눌림목 셋업 + DI 재가속 / pullback setup + DI re-accel")
