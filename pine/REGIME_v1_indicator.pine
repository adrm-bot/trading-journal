//@version=6
// REGIME v1.1 — 5-상태 레짐 분류기 (research/regime 파이썬 구현의 차트 포팅)
//
// 산출물 계약: 캔들마다 {레짐, confidence} 만. 예측·목표가·시그널 없음.
// 5상태(색): 🟢상승추세 / 🔴하락추세 / 🔵수렴(돌파대기) / ⚪박스권 / 🟠난장판(관망)
//
// 파라미터는 파이썬 리서치에서 동결된 값 그대로 (재튜닝 금지 — 포킹패스 규율).
// 검증된 사실(BTCUSDT 15m, 2022→2026 + ETH/SOL/XRP 무튜닝 복제):
//   - 원시 ADX(25) 대비 진입이 중앙값 4~6캔들 늦은 대신 churn −33%·오경보 ~0.07/100봉
//     — "늦지만 깨끗한" 레짐 게이트.
//   - 정직성 고지: OI 융합의 +1캔들 조기화는 시간이동 널과 구별 불가(p=1.0) — OI 정렬의
//     타이밍 알파는 미검출. ΔOI 하강(숏커버·청산)은 라벨 불변·확신만 삭감.
//   - confirm_bars=1 로 올리면 리드 희생 0에 churn 추가 −26%.
// 알림은 반드시 "Once Per Bar Close"로 설정 (FSM이 확정 봉에서만 갱신 — 리페인트 방지).
indicator("REGIME v1 — 5-state regime [Gunner]", overlay = false, max_bars_back = 5000, max_labels_count = 100)

// ── 동결 파라미터 ────────────────────────────────────────────────────────────
adxLen   = input.int(14,  "ADX/DI 기간",       group = "동결 파라미터(리서치)")
adxLo    = input.float(20, "ADX 하한",          group = "동결 파라미터(리서치)")
adxScale = input.float(15, "ADX 스케일",        group = "동결 파라미터(리서치)")
emaFLen  = input.int(20,  "EMA fast",           group = "동결 파라미터(리서치)")
emaSLen  = input.int(50,  "EMA slow",           group = "동결 파라미터(리서치)")
bbLen    = input.int(20,  "BB 기간",            group = "동결 파라미터(리서치)")
bbK      = input.float(2.0, "BB 표준편차",      group = "동결 파라미터(리서치)")
qWin     = input.int(2880, "분위수 창(봉)",     group = "동결 파라미터(리서치)", tooltip = "15m에서 30일")
kOI      = input.int(8,   "ΔOI lookback(봉)",   group = "동결 파라미터(리서치)")
deadQ    = input.int(25,  "데드존 분위(%)",     group = "동결 파라미터(리서치)")
wDir     = 0.5
wVol     = 0.3
wFuel    = 0.2
nearTie  = 0.02
minDwell    = input.int(0, "min_dwell(봉)",     group = "hysteresis (기본 OFF)")
confirmBars = input.int(0, "confirm_bars(봉)",  group = "hysteresis (기본 OFF)", tooltip = "1로 올리면 리드 희생 없이 잦은 전환 −26% (리서치 스윕)")
// ── 표시 옵션 ────────────────────────────────────────────────────────────────
posStr   = input.string("우상단", "테이블 위치", options = ["좌상단", "중앙상단", "우상단", "좌중앙", "중앙", "우중앙", "좌하단", "중앙하단", "우하단"], group = "표시")
showLbl  = input.bool(true, "레짐 전환 마커(차트)", group = "표시")
tblSize  = input.string("보통", "테이블 글자", options = ["작게", "보통", "크게"], group = "표시")

// ── 피처 (전부 인과: 현재 봉 종가까지만) ────────────────────────────────────
[diP, diM, adx] = ta.dmi(adxLen, adxLen)
atr  = ta.rma(ta.tr(true), adxLen)
m    = (ta.ema(close, emaFLen) - ta.ema(close, emaSLen)) / atr
bbw  = 2 * bbK * ta.stdev(close, bbLen) / ta.sma(close, bbLen)
atrp = atr / close
volPct = (ta.percentrank(bbw, qWin) + ta.percentrank(atrp, qWin)) / 200.0  // 과거 전용

string oiSym = syminfo.prefix + ":" + syminfo.ticker + "_OI"
oiClose = request.security(oiSym, timeframe.period, close, ignore_invalid_symbol = true)
oiOk    = not na(oiClose) and not na(oiClose[kOI])
doi     = oiOk ? (oiClose - oiClose[kOI]) / oiClose[kOI] : na
dpr     = (close - close[kOI]) / close[kOI]
dzDoi   = ta.percentile_nearest_rank(math.abs(doi[1]), qWin, deadQ)   // 과거 전용(1봉 시프트)
dzDpr   = ta.percentile_nearest_rank(math.abs(dpr[1]), qWin, deadQ)
quadOn = oiOk and not na(dzDoi) and not na(dzDpr) and math.abs(doi) >= dzDoi and math.abs(dpr) >= dzDpr
quad   = not quadOn ? 0 : doi > 0 and dpr > 0 ? 1 : doi > 0 and dpr < 0 ? 2 : doi < 0 and dpr > 0 ? 3 : doi < 0 and dpr < 0 ? 4 : 0

// ── 축 점수 → 5상태 ─────────────────────────────────────────────────────────
tanhPos(float x) =>
    float xc = math.min(x, 20.0)
    float e2 = math.exp(2.0 * xc)
    (e2 - 1.0) / (e2 + 1.0)

a      = math.max(0.0, math.min(1.0, (adx - adxLo) / adxScale))
tRaw   = a * tanhPos(math.abs(m))
agreeD = math.sign(diP - diM) == math.sign(m)
T      = agreeD ? tRaw : tRaw * 0.5
dirUp   = m > 0 ? T : 0.0
dirDn   = m < 0 ? T : 0.0
dirRest = (1.0 - dirUp - dirDn) / 3.0
muL = math.max(0.0, math.min(1.0, (0.25 - volPct) / 0.10))
muH = math.max(0.0, math.min(1.0, (volPct - 0.75) / 0.10))
muM = math.max(0.0, 1.0 - muL - muH)

fuelVotes = quad == 1 or quad == 2
wPresent  = wDir + wVol + (fuelVotes ? wFuel : 0.0)
sUP = (wDir * dirUp   + (quad == 1 ? wFuel : 0.0)) / wPresent
sDN = (wDir * dirDn   + (quad == 2 ? wFuel : 0.0)) / wPresent
sSQ = (wDir * dirRest + wVol * muL) / wPresent
sRA = (wDir * dirRest + wVol * muM) / wPresent
sCH = (wDir * dirRest + wVol * muH) / wPresent

// argmax + 니어타이 현직 우선 + 온라인 FSM(확정 봉 스탬프, 역서명 없음)
var int cur = -1
var int pending = -1
var int pendCnt = 0
var int sinceSwitch = 100000
score(i) => i == 0 ? sUP : i == 1 ? sDN : i == 2 ? sSQ : i == 3 ? sRA : sCH
int best = 0
float bestV = sUP
if sDN > bestV
    best := 1
    bestV := sDN
if sSQ > bestV
    best := 2
    bestV := sSQ
if sRA > bestV
    best := 3
    bestV := sRA
if sCH > bestV
    best := 4
    bestV := sCH
bool ready = not na(volPct) and not na(m) and not na(adx)
if ready and barstate.isconfirmed
    int cand = cur >= 0 and score(cur) >= bestV - nearTie ? cur : best
    if cur < 0
        cur := cand
        sinceSwitch := 0
    else if cand != cur
        pendCnt := cand == pending ? pendCnt + 1 : 1
        pending := cand
        if pendCnt >= confirmBars + 1 and sinceSwitch >= minDwell
            cur := cand
            sinceSwitch := 0
            pending := -1
            pendCnt := 0
    else
        pending := -1
        pendCnt := 0
    sinceSwitch += 1
else if not ready and barstate.isconfirmed
    cur := -1
    pending := -1
    pendCnt := 0
    sinceSwitch := 100000

// confidence = 합의 × 마진 × 수정자, [0,1] 클램프
float agreement = ready and cur >= 0 ? score(cur) : na
float runnerUp = 0.0
if ready and cur >= 0
    for i = 0 to 4
        if i != cur and score(i) > runnerUp
            runnerUp := score(i)
bool dzDefined = oiOk and not na(dzDoi) and not na(dzDpr)
float fuelMod = quad == 3 or quad == 4 ? 0.85 : dzDefined and quad == 0 ? 0.95 : 1.0
float conf = na(agreement) ? na : math.max(0.0, math.min(1.0, agreement * (1.0 - 0.5 * (agreement > 1e-12 ? runnerUp / agreement : 2.0)) * fuelMod * (dzDefined ? 1.0 : 0.8)))

// ── 상태 이름·색 (범례와 리본이 같은 색을 씀 — "무슨 색=무슨 시장") ─────────
color stCol = cur == 0 ? color.green : cur == 1 ? color.red : cur == 2 ? color.blue : cur == 3 ? color.gray : color.orange
nameOf(i) => i == 0 ? "상승추세" : i == 1 ? "하락추세" : i == 2 ? "수렴(돌파대기)" : i == 3 ? "박스권" : i == 4 ? "난장판(관망)" : "준비 중"
emojiOf(i) => i == 0 ? "🟢" : i == 1 ? "🔴" : i == 2 ? "🔵" : i == 3 ? "⚪" : i == 4 ? "🟠" : "…"

// 리본: 메인 차트 배경 (진할수록 확신 높음)
int transp = na(conf) ? 90 : int(90 - 70 * math.min(conf / 0.6, 1.0))
bgcolor(ready ? color.new(stCol, transp) : na, title = "regime ribbon", force_overlay = true)

// 전환 마커: 과거로 스크롤하며 "언제 무슨 시장으로 바뀌었나" 확인용
if showLbl and barstate.isconfirmed and cur >= 0 and cur != cur[1]
    label.new(bar_index, na, emojiOf(cur) + " " + nameOf(cur), yloc = yloc.abovebar, style = label.style_label_down, color = color.new(stCol, 25), textcolor = color.white, size = size.small, force_overlay = true)

// 확신도 서브패널
plot(conf, "confidence", color = color.new(color.blue, 0), linewidth = 1)
confQ20 = ta.percentile_nearest_rank(conf[1], qWin, 20)
plot(confQ20, "conf rolling q20", color = color.new(color.gray, 40), style = plot.style_line)
collapse = not na(conf) and not na(conf[1]) and not na(confQ20) and not na(confQ20[1]) and conf < confQ20 and conf[1] < confQ20[1]
plotshape(collapse, "confidence collapse", style = shape.xcross, location = location.bottom, color = color.new(color.red, 0), size = size.tiny)

// ── 상태 테이블 (메인 차트 위, 위치 선택 가능) ──────────────────────────────
posOf(string s) =>
    s == "좌상단" ? position.top_left : s == "중앙상단" ? position.top_center : s == "우상단" ? position.top_right : s == "좌중앙" ? position.middle_left : s == "중앙" ? position.middle_center : s == "우중앙" ? position.middle_right : s == "좌하단" ? position.bottom_left : s == "중앙하단" ? position.bottom_center : position.bottom_right
txtSz = tblSize == "작게" ? size.small : tblSize == "크게" ? size.large : size.normal

// 확신 등급: 절대값(상한 ~0.6)이 아니라 "최근 30일 나 자신 대비" 분위로 번역
confPct = ta.percentrank(conf, qWin)

doTxt(i) => i == 0 ? "눌림목 롱 · 돌파 따라가기" : i == 1 ? "반등 숏 · 붕괴 따라가기" : i == 2 ? "돌파 대기 · 레벨 알림 세팅" : i == 3 ? "박스 상/하단 역매매" : "관망 · 사이즈 축소"
dontTxt(i) => i == 0 ? "역추세 숏 · 물타기" : i == 1 ? "역추세 롱 · 나이프 캐칭" : i == 2 ? "미리 추세 베팅 · 잦은 스캘프" : i == 3 ? "추세추종 · 돌파 추격" : "방향 베팅 전부 · 복수 매매"

var table tb = table.new(posOf(posStr), 2, 7, border_width = 1, force_overlay = true)
if barstate.islast
    string gradeTxt = na(confPct) ? "계산 중…" : (confPct >= 70 ? "높음 ●●●" : confPct >= 30 ? "보통 ●●○" : "낮음 ●○○") + "  (" + str.tostring(conf, "0.00") + ")"
    string dataTxt = dzDefined ? "정상 (OI 포함)" : "OI 준비/끊김 → 보수 모드(확신 하향)"
    table.cell(tb, 0, 0, "지금 시장", text_size = txtSz)
    table.cell(tb, 1, 0, emojiOf(cur) + " " + nameOf(cur), text_color = color.white, bgcolor = stCol, text_size = txtSz)
    table.cell(tb, 0, 1, "판단 확신", text_size = txtSz)
    table.cell(tb, 1, 1, gradeTxt, text_size = txtSz, tooltip = "최근 30일의 나 자신과 비교한 상대 등급")
    table.cell(tb, 0, 2, "지금 할 것", text_size = txtSz)
    table.cell(tb, 1, 2, cur >= 0 ? doTxt(cur) : "…", text_size = txtSz)
    table.cell(tb, 0, 3, "하지 말 것", text_size = txtSz)
    table.cell(tb, 1, 3, cur >= 0 ? dontTxt(cur) : "…", text_size = txtSz, text_color = color.new(color.red, 20))
    table.cell(tb, 0, 4, "데이터", text_size = txtSz)
    table.cell(tb, 1, 4, dataTxt, text_size = txtSz)
    table.cell(tb, 0, 5, collapse ? "⚠ 전환 경고" : "", text_size = txtSz, bgcolor = collapse ? color.new(color.red, 70) : na)
    table.cell(tb, 1, 5, collapse ? "확신 급락 — 시장 성격이 바뀌는 중일 수 있음. 사이즈 축소" : "", text_size = txtSz, bgcolor = collapse ? color.new(color.red, 70) : na)
    table.cell(tb, 0, 6, "색 안내", text_size = size.small)
    table.cell(tb, 1, 6, "🟢상승 🔴하락 🔵수렴 ⚪박스 🟠난장", text_size = size.small, text_color = color.new(color.gray, 20))

alertcondition(ta.change(cur) != 0, "Regime change", "REGIME v1: 레짐 전환")
alertcondition(collapse, "Confidence collapse", "REGIME v1: 확신 급락 — 전환 가능성")
