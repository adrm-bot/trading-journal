//@version=6
// REGIME v1.7 — 5-상태 레짐 분류기 (research/regime 파이썬 구현의 차트 포팅)
// v1.7: 밴드 기본 2단(위=현재 · 아래=상위 TF) — 하위 TF 밴드는 실측 기각 후 옵션 강등
//        (30일 라이브 측정: 15m 전환 선행률 54% = 기저 일치율 55%와 동일 → 선행정보 0,
//         플리커 2.7배, TV 하위TF security는 샘플링이라 원래 열화 데이터)
//        · 확신선 2줄 분리(위 반=현재 TF conf, 아래 반=상위 TF 2축 근사 conf)
//        · X(확신급락 온셋)도 밴드별: 위 X=현재 TF, 아래 X=상위 TF(동일 정의: 자기 30일
//          하위 20% 미만 2봉 연속의 첫 봉)
//        · 테이블: 권고 행을 권장/금지 2행으로 분리 + 긴 문장 셀 내 줄바꿈(테이블 폭 관리)
// v1.6: 테이블 리페인트 완치(전 셀 확정봉 스냅샷 — 실측: 표시 0.09 vs 정본 0.35 불일치 제거)
//        · 표류(드리프트) 태그: 비추세 라벨 + |24h 순이동|≥2% AND ER(24h)≥0.10, 히스테리시스
//          (4년 캘리브: 비추세 봉의 23.5% 발화 · 과거 기술일 뿐 방향 엣지 없음 — 전방지속 ~0.43)
//        · 근접 2위 표기(점수비≥0.85 — 4년: 표기 후 8봉 내 전환 71% vs 기저 35%)
//        · 상위 TF 동적 사다리(자기 TF 제외: 1H차트→4H·12H·1D 등) · 플레이북 충돌 문구
//          (검증 continuation_study: HTF추세×LTF박스 전방 share_up 0.485~0.527 — 방향 조언 금지,
//           '박스 레벨 신뢰 낮음'만 전달) · 리본 강도 3단(기본 은은) · collapse 마커/알림 온셋만
//        · OI 데드존 분위: 정렬 링버퍼(과거전용·부분창 min 2/3 — 파이썬 min_periods 패리티,
//          OI 워밍업 30일 과잉 ×0.8 패널티 제거) · OI 피드 소스 고정(per-bar 혼합 방지)
//        · 미구현 패리티(문서화): 펀딩 극단 트림 ×0.90(classifier.py 155행) — TV 펀딩 피드 부재
// v1.4: MTF 3분할 밴드(위 하위TF·중간 현재·아래 상위TF) · 마커 '성김' 모드 · 5m 창 캡
//        · TV 데이터 패리티 검증(MCP: TV 봉 = Binance REST 봉, Δ=0)
//
// 산출물 계약: 캔들마다 {레짐, confidence} 만. 셋업/전환감시 행은 표시 레이어(분류기 불변).
// 5상태(색): 🟢상승추세 / 🔴하락추세 / 🔵수렴(돌파대기) / ⚪박스권 / 🟠스퀴즈(관망)
//
// v1.3 기본기 강화:
//   - 창 길이 벽시계 자동 스케일링(30일) — 어떤 TF 차트에서도 동일 의미 (기존: 15m 고정 봉수)
//   - 상위 방향 1H·4H·1D 통합 행 / 눌림목 셋업 행(ADX_Gunner 규칙) / 전환 감시 행(엄격)
//   - 테이블 배경(다크 차트 가독성) / 확신선 레짐 색 / 한·영 토글
//
// 검증된 사실(BTC 15m 2022→2026 + ETH/SOL/XRP 복제, 외부감사 Codex 반영):
//   - 라벨 = 시장 '성격'(변동성 구조) 기술. 방향 예측력 없음 — 방향·레버리지는 상위 TF.
//   - 눌림목 서식지(H1 추세+15m 수렴/박스) 자체는 통계 엣지 없음(사전등록 검증, 중앙값 약음)
//     → 셋업 행은 '후보+트리거' 감지일 뿐, 엣지는 트리거·손절 구조가 만들어야 함.
//   - OI 융합의 조기화는 널 대비 우월 증거 없음(p=1.0). confirm_bars=1 = 리드 희생 0에 churn −26%.
// 알림은 반드시 "Once Per Bar Close"로 (확정 봉에서만 갱신 — 리페인트 방지).
indicator("REGIME v1 — 5-state regime [Gunner]", overlay = false, max_bars_back = 5000, max_labels_count = 100)

// ── 언어 ─────────────────────────────────────────────────────────────────────
lang = input.string("한국어", "언어 / Language", options = ["한국어", "English"], group = "표시 / Display")
L(string k, string e) => lang == "한국어" ? k : e

// ── 동결 파라미터 (봉수는 벽시계 자동 스케일) ────────────────────────────────
adxLen   = input.int(14,  "ADX/DI 기간",       group = "동결 파라미터(리서치)")
adxLo    = input.float(20, "ADX 하한",          group = "동결 파라미터(리서치)")
adxScale = input.float(15, "ADX 스케일",        group = "동결 파라미터(리서치)")
emaFLen  = input.int(20,  "EMA fast",           group = "동결 파라미터(리서치)")
emaSLen  = input.int(50,  "EMA slow",           group = "동결 파라미터(리서치)")
bbLen    = input.int(20,  "BB 기간",            group = "동결 파라미터(리서치)")
bbK      = input.float(2.0, "BB 표준편차",      group = "동결 파라미터(리서치)")
deadQ    = input.int(25,  "데드존 분위(%)",     group = "동결 파라미터(리서치)")
wDir     = 0.5
wVol     = 0.3
wFuel    = 0.2
nearTie  = 0.02
minDwell    = input.int(0, "min_dwell(봉)",     group = "hysteresis (기본 OFF)")
confirmBars = input.int(0, "confirm_bars(봉)",  group = "hysteresis (기본 OFF)", tooltip = "1로 올리면 전환 판정을 한 봉 더 확인한 뒤 확정합니다. 검증 결과 판정이 늦어지는 손해 없이 잦은 전환만 26% 줄었습니다.")

// 벽시계 스케일링: 리서치 동결값(15m 기준 30일=2880봉, ΔOI 2시간=8봉)을 TF 무관 유지
int tfSec = timeframe.in_seconds()
int barsPerDay = math.max(1, math.round(86400.0 / tfSec))
// 30일 분위수 창. 상한 4000봉 = max_bars_back 예산(5m에선 ~14일로 캡 — 문서화된 근사)
int qWin = math.min(4000, math.max(200, 30 * barsPerDay))
int kOI  = math.max(1, math.round(7200.0 / tfSec))   // ΔOI lookback = 2시간
int dipLB = math.max(8, math.round(28800.0 / tfSec)) // '최근 하락 경유' = 8시간

// ── 표시 옵션 ────────────────────────────────────────────────────────────────
posStr   = input.string("우상단", "테이블 위치", options = ["좌상단", "중앙상단", "우상단", "좌중앙", "중앙", "우중앙", "좌하단", "중앙하단", "우하단"], group = "표시 / Display")
showMain = input.bool(true, "메인 차트 리본", group = "표시 / Display", tooltip = "가격 차트 배경 색칠 on/off — 다른 지표 배경과 겹쳐 어지러우면 끄기")
ribInt   = input.string("은은", "메인 리본 강도", options = ["은은", "보통", "진하게"], group = "표시 / Display", tooltip = "배경 색의 진하기입니다. 은은(기본)은 최대 불투명 15%로 캔들 가독성을 우선합니다. 보통은 30%, 진하게는 62%까지 진해집니다.")
lblDensity = input.string("성김", "전환 마커", options = ["전부", "성김", "끄기"], group = "표시 / Display", tooltip = "성김(기본)은 1봉 이상 유지된 전환만, 최소 8봉 간격으로 표시합니다 — 빠른 타임프레임에서 마커가 쏟아지는 것을 막아줍니다.")
bandMode = input.string("2단(현재 위 · 상위 아래)", "레짐 밴드", options = ["2단(현재 위 · 상위 아래)", "3단(하위 TF 포함)", "끄기"], group = "표시 / Display", tooltip = "기본 2단은 위 반이 현재 타임프레임, 아래 반이 한 단계 위 타임프레임입니다(각자 확신선과 X 표시). 하위 타임프레임 밴드는 측정 결과 전환을 먼저 보여주지 못했고(선행률 54% = 우연 수준 55%) 깜빡임만 2.7배라 기본에서 제외했습니다 — 원하면 3단으로 켤 수 있습니다.")
bool showBands = bandMode != "끄기"
bool band3 = bandMode == "3단(하위 TF 포함)"
tblSize  = input.string("작게", "테이블 글자", options = ["아주작게", "작게", "보통", "크게"], group = "표시 / Display")

// ── 피처 (전부 인과: 현재 봉 종가까지만) ────────────────────────────────────
[diP, diM, adx] = ta.dmi(adxLen, adxLen)
atr  = ta.rma(ta.tr(true), adxLen)
m    = (ta.ema(close, emaFLen) - ta.ema(close, emaSLen)) / atr
bbw  = 2 * bbK * ta.stdev(close, bbLen) / ta.sma(close, bbLen)
atrp = atr / close
volPct = (ta.percentrank(bbw, qWin) + ta.percentrank(atrp, qWin)) / 200.0  // 과거 전용

// OI 피드: 현재 심볼 → 없으면 무기한(.P) 폴백 (현물 차트 대응)
// 소스는 최초 유효 시점에 고정 — per-bar 스위칭이 만들 가짜 ΔOI 스파이크 방지 (패리티 감사)
string oiSym  = syminfo.prefix + ":" + syminfo.ticker + "_OI"
string oiSymP = syminfo.prefix + ":" + syminfo.ticker + ".P_OI"
oi1 = request.security(oiSym, timeframe.period, close, ignore_invalid_symbol = true)
oi2 = request.security(oiSymP, timeframe.period, close, ignore_invalid_symbol = true)
var int oiSrc = 0
if oiSrc == 0
    oiSrc := not na(oi1) ? 1 : not na(oi2) ? 2 : 0
oiClose = oiSrc == 1 ? oi1 : oiSrc == 2 ? oi2 : na
bool oiFromPerp = oiSrc == 2
oiOk    = not na(oiClose) and not na(oiClose[kOI])
doi     = oiOk ? (oiClose - oiClose[kOI]) / oiClose[kOI] : na
dpr     = (close - close[kOI]) / close[kOI]
// OI 데드존 분위: 정렬 링버퍼(과거 전용 — 현재 봉 값을 넣기 '전'에 판독).
// ta.percentile_nearest_rank는 만창(30일)+무결측을 요구해 OI 워밍업/갭에서 30일간
// fuelDefined=false → ×0.8 과잉 패널티가 걸렸음. 파이썬 정본은 min_periods=20일(창의 2/3)
// + NaN 스킵 — min_periods 동작만 재현. 잔여 차이(문서화): ① 분위 보간 nearest-rank vs
// pandas 선형보간 ② 창 기준 '최근 N개 유효값' vs '최근 N행'(장기 OI 결측 시 상이)
// ③ dzDpr은 만창 유지 ④ 4h+ qWin 바닥값 200 vs 정본 180 — 전부 경계/갭 국면 한정 소폭.
int dzMinOI = math.max(2, qWin * 2 / 3)
var array<float> dzRawOI = array.new_float()
var array<float> dzSrtOI = array.new_float()
var float dzDoi = na
if barstate.isconfirmed
    dzDoi := array.size(dzSrtOI) >= dzMinOI ?
         array.get(dzSrtOI, math.max(0, int(math.ceil(deadQ / 100.0 * array.size(dzSrtOI))) - 1)) : na
    if not na(doi)
        float av = math.abs(doi)
        array.push(dzRawOI, av)
        // 삽입점 정규화 — binary_search_leftmost는 '미발견 시 floor(왼쪽 이웃) 인덱스'를
        // 반환하므로(bisect_left 아님) 그대로 insert하면 정렬 파괴 + 신저값에서 -1 에러
        int n = array.size(dzSrtOI)
        int ix = n == 0 ? 0 : array.binary_search_leftmost(dzSrtOI, av)
        ix := ix < 0 ? 0 : ix >= n ? n : array.get(dzSrtOI, ix) < av ? ix + 1 : ix
        array.insert(dzSrtOI, ix, av)
        if array.size(dzRawOI) > qWin
            float ev = array.shift(dzRawOI)   // push한 값 그대로(bit-identical) — 존재 보장
            int rn = array.size(dzSrtOI)
            int rix = rn == 0 ? -1 : array.binary_search_leftmost(dzSrtOI, ev)
            if rix >= 0 and rix < rn and array.get(dzSrtOI, rix) == ev
                array.remove(dzSrtOI, rix)
            else
                int fi = array.indexof(dzSrtOI, ev)   // 안전망(이론상 도달 불가)
                if fi >= 0
                    array.remove(dzSrtOI, fi)
dzDpr = ta.percentile_nearest_rank(math.abs(dpr[1]), qWin, deadQ)   // 가격은 결측 희귀 — 기존 유지
// fuelDefined: 파이썬 fuel_defined = doi.notna & dz_doi.notna (dz_dpr는 조건 아님 — 패리티 수정)
bool fuelDefined = oiOk and not na(dzDoi)
quadOn = fuelDefined and not na(dzDpr) and math.abs(doi) >= dzDoi and math.abs(dpr) >= dzDpr
quad   = not quadOn ? 0 : doi > 0 and dpr > 0 ? 1 : doi > 0 and dpr < 0 ? 2 : doi < 0 and dpr > 0 ? 3 : doi < 0 and dpr < 0 ? 4 : 0

// ── 축 점수 → 5상태 ─────────────────────────────────────────────────────────
tanhPos(float x) =>
    float xc = math.min(x, 20.0)
    float e2 = math.exp(2.0 * xc)
    (e2 - 1.0) / (e2 + 1.0)

a      = math.max(0.0, math.min(1.0, (adx - adxLo) / adxScale))
tRaw   = a * tanhPos(math.abs(m))
agreeD = math.sign(diP - diM) == math.sign(m)
T      = agreeD ? tRaw : tRaw * 0.5
dirUp   = m > 0 ? T : 0.0
dirDn   = m < 0 ? T : 0.0
dirRest = (1.0 - dirUp - dirDn) / 3.0
muL = math.max(0.0, math.min(1.0, (0.25 - volPct) / 0.10))
muH = math.max(0.0, math.min(1.0, (volPct - 0.75) / 0.10))
muM = math.max(0.0, 1.0 - muL - muH)

fuelVotes = quad == 1 or quad == 2
wPresent  = wDir + wVol + (fuelVotes ? wFuel : 0.0)
sUP = (wDir * dirUp   + (quad == 1 ? wFuel : 0.0)) / wPresent
sDN = (wDir * dirDn   + (quad == 2 ? wFuel : 0.0)) / wPresent
sSQ = (wDir * dirRest + wVol * muL) / wPresent
sRA = (wDir * dirRest + wVol * muM) / wPresent
sCH = (wDir * dirRest + wVol * muH) / wPresent

// argmax + 니어타이 현직 우선 + 온라인 FSM(확정 봉 스탬프, 역서명 없음)
var int cur = -1
var int pending = -1
var int pendCnt = 0
var int sinceSwitch = 100000
score(i) => i == 0 ? sUP : i == 1 ? sDN : i == 2 ? sSQ : i == 3 ? sRA : sCH
int best = 0
float bestV = sUP
if sDN > bestV
    best := 1
    bestV := sDN
if sSQ > bestV
    best := 2
    bestV := sSQ
if sRA > bestV
    best := 3
    bestV := sRA
if sCH > bestV
    best := 4
    bestV := sCH
bool ready = not na(volPct) and not na(m) and not na(adx)
if ready and barstate.isconfirmed
    int cand = cur >= 0 and score(cur) >= bestV - nearTie ? cur : best
    if cur < 0
        cur := cand
        sinceSwitch := 0
    else if cand != cur
        pendCnt := cand == pending ? pendCnt + 1 : 1
        pending := cand
        if pendCnt >= confirmBars + 1 and sinceSwitch >= minDwell
            cur := cand
            sinceSwitch := 0
            pending := -1
            pendCnt := 0
    else
        pending := -1
        pendCnt := 0
    sinceSwitch += 1
else if not ready and barstate.isconfirmed
    cur := -1
    pending := -1
    pendCnt := 0
    sinceSwitch := 100000

// confidence = 합의 × 마진 × 수정자, [0,1] 클램프
float agreement = ready and cur >= 0 ? score(cur) : na
float runnerUp = 0.0
int runnerIdx = -1
if ready and cur >= 0
    for i = 0 to 4
        if i != cur and score(i) > runnerUp
            runnerUp := score(i)
            runnerIdx := i
// 미구현 패리티(정직 표기): 펀딩 극단(percentile≥0.95/≤0.05) 시 TREND 확신 ×0.90 트림은
// TV에 펀딩 피드가 없어 이식 불가 — 파이썬 정본 대비 TREND·펀딩 극단 구간 conf 최대 +11%.
float fuelMod = quad == 3 or quad == 4 ? 0.85 : fuelDefined and quad == 0 ? 0.95 : 1.0
float conf = na(agreement) ? na : math.max(0.0, math.min(1.0, agreement * (1.0 - 0.5 * (agreement > 1e-12 ? runnerUp / agreement : 2.0)) * fuelMod * (fuelDefined ? 1.0 : 0.8)))

// 확신 급락(collapse) — 실시간 봉은 직전 확정값 사용(리페인트 없음). 셋업/전환감시가 공용
// 스냅샷 패턴: isconfirmed ? x : x[1] — 형성 중 틱은 직전 확정값(무리페인트), 마감 틱은
// 그 봉의 확정값을 커밋 → 히스토리 재계산과 완전 일치(리로드 이동·1봉 지연 없음)
float confShow = barstate.isconfirmed ? conf : conf[1]
confQ20 = ta.percentile_nearest_rank(conf[1], qWin, 20)
float confQ20Show = barstate.isconfirmed ? confQ20 : confQ20[1]
collapse = not na(confShow) and not na(confShow[1]) and not na(confQ20Show) and not na(confQ20Show[1]) and confShow < confQ20Show and confShow[1] < confQ20Show[1]
int sinceCollapse = ta.barssince(collapse)
bool recentClps = not na(sinceCollapse) and sinceCollapse <= 4

// ── 확정봉 스냅샷 (표시층 전용) — 테이블·리본 intra-bar 리페인트 방지 ─────────
// v1.5까지 테이블이 실시간 틱값(conf·quad·등급)을 표시해 확정 정본과 크게 어긋났음
// (실측 2026-07-05: 표시 0.09 vs 파이썬 확정 0.35). FSM 라벨(cur)은 원래 확정 게이트.
int  quadShow    = barstate.isconfirmed ? quad : quad[1]
bool fuelDefShow = barstate.isconfirmed ? fuelDefined : fuelDefined[1]
confPct = ta.percentrank(conf, qWin)   // 확신의 30일 자기 분위(등급용)
float confPctShow = barstate.isconfirmed ? confPct : confPct[1]
// 근접 2위(확정 스냅샷): 점수비 ≥0.85 — 4년 캘리브: 표기 후 8봉 내 전환 71% vs 기저 35%
var float rrShow = na
var int   rrIdxShow = -1
if barstate.isconfirmed
    rrShow := ready and cur >= 0 and agreement > 1e-12 ? runnerUp / agreement : na
    rrIdxShow := ready and cur >= 0 ? runnerIdx : -1

// ── 표류(드리프트) 태그 — 표시층 전용, 분류기 출력 불변 ─────────────────────
// 게이트(4년 캘리브 정본: research/regime/results/display_calib.json):
// on |24h 순이동|≥2% AND ER(24h)≥0.10 / off <1.5% or <0.08
// (비추세 봉 23.5% 발화, 히스테리시스로 전환수 −39%). ER=칸프만 효율비(순이동/경로합).
// 정직성: '지난 24h' 과거 기술 — 표류-on 코호트 자체 실측 전방지속 0.46~0.47(엣지 없음),
// 추종 신호 아님. 의미: 박스 경계가 이동 중 → 레인지 페이드의 전제(레벨 정상성) 붕괴 경고.
float net24  = close / close[barsPerDay] - 1.0
float path24 = math.sum(math.abs(close - close[1]), barsPerDay)
float er24   = na(path24) or path24 <= 0 ? na : math.abs(close - close[barsPerDay]) / path24
var bool  driftOn  = false
var float driftVal = na
if barstate.isconfirmed
    if na(net24) or na(er24)
        driftOn := false
    else if not driftOn and math.abs(net24) >= 0.02 and er24 >= 0.10
        driftOn := true
    else if driftOn and (math.abs(net24) < 0.015 or er24 < 0.08)
        driftOn := false
    driftVal := net24
bool driftTfOk = tfSec == 900 or tfSec == 3600   // 캘리브 검증 TF 화이트리스트(15m·1h) — 파이썬 두 표면과 동일. 그 외 TF는 24h 창 ER 분포 미측정

// ── 상태 이름·색 ─────────────────────────────────────────────────────────────
color stCol = cur == 0 ? color.green : cur == 1 ? color.red : cur == 2 ? color.blue : cur == 3 ? color.gray : color.orange
nameOf(i) => i == 0 ? L("상승추세", "Uptrend") : i == 1 ? L("하락추세", "Downtrend") : i == 2 ? L("수렴(돌파대기)", "Squeeze") : i == 3 ? L("박스권", "Range") : i == 4 ? L("스퀴즈(관망)", "Chop") : L("준비 중", "Warming up")
emojiOf(i) => i == 0 ? "🟢" : i == 1 ? "🔴" : i == 2 ? "🔵" : i == 3 ? "⚪" : i == 4 ? "🟠" : "…"

// 메인 차트 리본 (진할수록 확신 높음 — 확정값 confShow 기준, 리페인트 없음)
// 강도 3단: 은은 97→85(기본, 최대 불투명 15%) · 보통 94→70 · 진하게 90→38(v1.5 동작)
float ribR  = na(confShow) ? 0.0 : math.min(confShow / 0.6, 1.0)
int ribBase = ribInt == "은은" ? 97 : ribInt == "보통" ? 94 : 90
int ribSpan = ribInt == "은은" ? 12 : ribInt == "보통" ? 24 : 52
int transp  = na(confShow) ? 96 : int(ribBase - ribSpan * ribR)
bgcolor(ready and cur >= 0 and showMain ? color.new(stCol, transp) : na, title = "regime ribbon (main)", force_overlay = true)

// ── 상위 TF 사다리 (자기 TF 제외 — 동적: 15m→1H·4H·1D, 1H→4H·12H·1D, 4H→12H·1D·1W) ──
// v1.5까지 1H·4H·1D 고정이라 1H 차트에서 '상위 방향'에 자기 자신이 포함되는 결함이 있었음.
// 밴드(하위/상위)·상위 방향·셋업이 같은 사다리를 공유한다.
string tfLow  = tfSec <= 300 ? "5" : tfSec <= 900 ? "5" : tfSec <= 3600 ? "15" : tfSec <= 14400 ? "60" : tfSec <= 43200 ? "240" : tfSec <= 86400 ? "720" : "D"
string tfHigh = tfSec < 900 ? "15" : tfSec < 3600 ? "60" : tfSec < 14400 ? "240" : tfSec < 43200 ? "720" : tfSec < 86400 ? "D" : "W"
string htf2   = tfSec <= 300 ? "60" : tfSec <= 900 ? "240" : tfSec <= 3600 ? "720" : tfSec <= 14400 ? "D" : tfSec <= 43200 ? "W" : "M"
string htf3   = tfSec <= 300 ? "240" : tfSec <= 3600 ? "D" : tfSec <= 14400 ? "W" : tfSec <= 43200 ? "M" : "3M"
hName(string tf) => tf == "5" ? "5M" : tf == "15" ? "15M" : tf == "60" ? "1H" : tf == "240" ? "4H" : tf == "720" ? "12H" : tf == "D" ? "1D" : tf == "W" ? "1W" : tf == "M" ? "1M" : tf

// 상위 방향 (단순 ADX/DI, 확정 봉만 — 리페인트 방지)
f_htfDir() =>
    [dp, dm, ax] = ta.dmi(adxLen, adxLen)
    [dp[1], dm[1], ax[1]]
[dp1, dm1, ax1] = request.security(syminfo.tickerid, tfHigh, f_htfDir())
[dp2, dm2, ax2] = request.security(syminfo.tickerid, htf2,  f_htfDir())
[dp3, dm3, ax3] = request.security(syminfo.tickerid, htf3,  f_htfDir())
dirIcon(dp, dm, ax) => na(ax) ? "…" : ax >= 25 and dp > dm ? "🟢" : ax >= 25 and dm > dp ? "🔴" : "⚪"

// ── 눌림목 셋업 감지 (ADX_Gunner 규칙 이식 — 표시 레이어, 분류기 불변) ──────
// HTF 스윗스팟: 셋업 기준 상위 TF = 한 단계 위(tfHigh)
float hAx = ax1
float hDp = dp1
float hDm = dm1
string hTfName = hName(tfHigh)
bool hSweetUp = not na(hAx) and hAx >= 20 and hAx <= 40 and hDp > hDm
bool hSweetDn = not na(hAx) and hAx >= 20 and hAx <= 40 and hDm > hDp
bool hMature  = not na(hAx) and hAx > 40
// EMA 정배열(보조 확인)
e100 = ta.ema(close, 100)
e200 = ta.ema(close, 200)
e20  = ta.ema(close, emaFLen)
e50  = ta.ema(close, emaSLen)
bool stackUp = e20 > e50 and e50 > e100 and e100 > e200
bool stackDn = e20 < e50 and e50 < e100 and e100 < e200
// DI 재가속 트리거 (2봉 확정, ADX_Gunner식 단순판)
float spread = diP - diM
float sprAbs = math.abs(spread)
bool reUp = spread > 0 and sprAbs > sprAbs[1] and sprAbs - sprAbs[2] > 0
bool reDn = spread < 0 and sprAbs > sprAbs[1] and sprAbs - sprAbs[2] > 0
// 셋업 입력 확정 스냅샷 — 라이브 DI/EMA 틱값이 r3 셀을 봉 내에서 플리커시키는 것 방지
bool reUpS    = barstate.isconfirmed ? reUp : reUp[1]
bool reDnS    = barstate.isconfirmed ? reDn : reDn[1]
bool stackUpS = barstate.isconfirmed ? stackUp : stackUp[1]
bool stackDnS = barstate.isconfirmed ? stackDn : stackDn[1]
// 최근 반대 레그 경유(8h) — "하락 후 수렴" 요소 (barssince는 최초 발생 전 na → 가드)
int bsDn = ta.barssince(cur == 1)
int bsUp = ta.barssince(cur == 0)
bool dippedDn = not na(bsDn) and bsDn <= dipLB
bool dippedUp = not na(bsUp) and bsUp <= dipLB
bool inPB = cur == 2 or cur == 3   // 수렴/박스권
string setupTxt = na
if hMature
    setupTxt := "⚠ " + hTfName + " " + L("추세가 이미 과열 구간입니다(ADX 40 초과)\n지금 새로 올라타면 꼭지를 잡을 위험이 큽니다", "mature (ADX>40) — new entries risky")
else if hSweetUp and inPB
    // 검증(continuation_study): 횡보 중 확신급락은 재점화가 아니라 추세 '반대' 기울어짐(BTC/ETH 4h ↑44%)
    string warnL = recentClps ? " · ⚠" + L("판단 확신 급감 — 역방향 압력 주의", "collapse(counter-pressure)") : ""
    string ext = (stackUpS ? " · " + L("EMA 정배열", "EMA stacked") : "") + (dippedDn ? " · " + L("직전 하락 경유", "post-dip") : "") + warnL
    string base = reUpS ? "⚡ " + L("눌림목 롱 진입 신호 — DI 재가속이 확인됐습니다", "Pullback LONG — DI re-accel") : "🟡 " + L("눌림목 롱 후보 — 진입 신호(DI 재가속) 대기 중", "Pullback long candidate (await trigger)")
    setupTxt := ext == "" ? base : base + "\n" + str.substring(ext, 3)   // 태그는 둘째 줄로 (폭 관리)
else if hSweetDn and inPB
    string warnS = recentClps ? " · ⚠" + L("판단 확신 급감 — 역방향 압력 주의", "collapse(counter-pressure)") : ""
    string ext2 = (stackDnS ? " · " + L("EMA 역배열", "EMA stacked dn") : "") + (dippedUp ? " · " + L("직전 반등 경유", "post-pop") : "") + warnS
    string base2 = reDnS ? "⚡ " + L("되돌림 숏 진입 신호 — DI 재가속이 확인됐습니다", "Pullback SHORT — DI re-accel") : "🟡 " + L("되돌림 숏 후보 — 진입 신호(DI 재가속) 대기 중", "Pullback short candidate (await trigger)")
    setupTxt := ext2 == "" ? base2 : base2 + "\n" + str.substring(ext2, 3)
else
    setupTxt := L("현재 없음", "none")
bool setupTrig = (hSweetUp and inPB and reUpS) or (hSweetDn and inPB and reDnS)

// ── 전환 감시 (엄격: 2조건 동시 — 현직 열세 지속 + 최근 확신 급락) ──────────
var int negRun = 0
var int watchNext = -1
if barstate.isconfirmed
    bool losing = ready and cur >= 0 and runnerUp > score(cur)
    negRun := losing ? negRun + 1 : 0
    watchNext := losing ? runnerIdx : -1
bool watchOn = negRun >= 2 and not na(sinceCollapse) and sinceCollapse <= 8
string watchTxt = watchOn ? "⚠ " + L("판정이 흔들리고 있습니다 — 점수가 ", "votes shifting → #2: ") + emojiOf(watchNext) + " " + nameOf(watchNext) + L(" 쪽으로\n", " for ") + str.tostring(negRun) + L("봉째 기울고 있어 전환 확률이 높아졌습니다", " bars") : collapse ? "⚠ " + L("판단 확신이 급감했습니다 — 시장 성격이 바뀔 가능성이\n있으니 포지션을 줄이는 편이 안전합니다", "confidence collapse — possible shift, size down") : L("안정적입니다 — 현재 상태가 뚜렷하게 우세합니다", "stable — incumbent leads")

// 전환 마커 — '성김'(기본): 1봉 생존한 전환만 + 최소 8봉 간격 (빠른 TF 마커 홍수 방지)
var int lastLblBar = -100000
bool transRaw = barstate.isconfirmed and cur >= 0 and cur != cur[1]
bool transSurvived = barstate.isconfirmed and cur >= 0 and cur == cur[1] and cur[1] != cur[2]
if lblDensity == "전부" and transRaw
    label.new(bar_index, na, emojiOf(cur) + " " + nameOf(cur), yloc = yloc.abovebar, style = label.style_label_down, color = color.new(stCol, 25), textcolor = color.white, size = size.small, force_overlay = true)
if lblDensity == "성김" and transSurvived and bar_index - lastLblBar >= 8
    label.new(bar_index - 1, na, emojiOf(cur) + " " + nameOf(cur), yloc = yloc.abovebar, style = label.style_label_down, color = color.new(stCol, 25), textcolor = color.white, size = size.small, force_overlay = true)
    lastLblBar := bar_index

// ── MTF 3분할 밴드: 위=하위TF · 중간=현재TF · 아래=상위TF (사다리 5m→15m→1h→4h→12h→1D) ──
// 밴드용 2축 근사 레짐 (연료축 제외 — request.security 중첩 금지 + 연구상 연료 기여 p=1.0)
f_regime2(int qw) =>
    [dpL2, dmL2, axL2] = ta.dmi(adxLen, adxLen)   // 지역 이름 — 전역 dp2/dm2/ax2(htf2 security) 섀도잉 방지
    float atr2 = ta.rma(ta.tr(true), adxLen)
    float mm = (ta.ema(close, emaFLen) - ta.ema(close, emaSLen)) / atr2
    float vp = (ta.percentrank(2 * bbK * ta.stdev(close, bbLen) / ta.sma(close, bbLen), qw) + ta.percentrank(atr2 / close, qw)) / 200.0
    float aa = math.max(0.0, math.min(1.0, (axL2 - adxLo) / adxScale))
    float t0 = aa * tanhPos(math.abs(mm))
    float tt = math.sign(dpL2 - dmL2) == math.sign(mm) ? t0 : t0 * 0.5
    float up2 = mm > 0 ? tt : 0.0
    float dn2 = mm < 0 ? tt : 0.0
    float rs = (1.0 - up2 - dn2) / 3.0
    float mL2 = math.max(0.0, math.min(1.0, (0.25 - vp) / 0.10))
    float mH2 = math.max(0.0, math.min(1.0, (vp - 0.75) / 0.10))
    float mM2 = math.max(0.0, 1.0 - mL2 - mH2)
    float c0 = wDir * up2 / 0.8
    float c1 = wDir * dn2 / 0.8
    float c2 = (wDir * rs + wVol * mL2) / 0.8
    float c3 = (wDir * rs + wVol * mM2) / 0.8
    float c4 = (wDir * rs + wVol * mH2) / 0.8
    int b = 0
    float bv = c0
    if c1 > bv
        b := 1
        bv := c1
    if c2 > bv
        b := 2
        bv := c2
    if c3 > bv
        b := 3
        bv := c3
    if c4 > bv
        b := 4
        bv := c4
    float agree2 = bv
    float run2 = 0.0
    for i2 = 0 to 4
        float si = i2 == 0 ? c0 : i2 == 1 ? c1 : i2 == 2 ? c2 : i2 == 3 ? c3 : c4
        if i2 != b and si > run2
            run2 := si
    float cf2 = math.max(0.0, math.min(1.0, agree2 * (1.0 - 0.5 * (agree2 > 1e-12 ? run2 / agree2 : 2.0))))
    int bOut = na(vp) or na(mm) or na(axL2) ? -1 : b
    float cOut = na(vp) or na(mm) or na(axL2) ? na : cf2
    [bOut[1], cOut[1]]  // 확정 봉만 (비리페인트) — [상태, 확신]

bool hasLow = tfSec > 300  // 5m가 사다리 최하단 (tfLow/tfHigh는 상위 TF 사다리 절에서 정의)
qwFor(string tf) =>
    tf == "5" ? 4000 : tf == "15" ? 2880 : tf == "60" ? 720 : 200
[stLow, cfLow]   = request.security(syminfo.tickerid, tfLow,  f_regime2(qwFor(tfLow)))
[stHigh, cfHigh] = request.security(syminfo.tickerid, tfHigh, f_regime2(qwFor(tfHigh)))
int stH = na(stHigh) ? -1 : stHigh   // 한 단계 위 TF 레짐 (2축 근사, 확정 봉)
f_stateCol(int i) => na(i) ? color.new(color.gray, 80) : i == 0 ? color.green : i == 1 ? color.red : i == 2 ? color.blue : i == 3 ? color.gray : i == 4 ? color.orange : color.new(color.gray, 80)
// 확신 → 불투명도 그라데이션 (선이 위에서 읽히도록 밴드는 메인 리본보다 연하게)
f_bandT(float cf) => na(cf) ? 88 : int(86 - 52 * math.min(cf / 0.6, 1.0))
color colLow  = showBands and hasLow and not na(stLow) ? color.new(f_stateCol(stLow), f_bandT(cfLow)) : na
color colCur  = showBands and ready and cur >= 0 ? color.new(stCol, f_bandT(confShow)) : na
color colHigh = showBands and not na(stHigh) ? color.new(f_stateCol(stHigh), f_bandT(cfHigh)) : na
// 밴드가 패널을 채우고, 확신선이 그 위에 겹쳐 그려짐
// 2단(기본): 위 반=현재 TF · 아래 반=상위 TF / 3단(옵션): 위=하위 · 중간=현재 · 아래=상위
float lvA = band3 ? 0.6667 : 0.5
float lvB = band3 ? 0.3333 : 0.5
pB0 = plot(showBands ? 1.0 : na, "밴드경계1", color = color.new(color.gray, 100), editable = false)
pB1 = plot(showBands ? lvA : na, "밴드경계2", color = color.new(#000000, 55), editable = false, linewidth = 1)
pB2 = plot(showBands ? lvB : na, "밴드경계3", color = color.new(#000000, 55), editable = false, linewidth = 1)
pB3 = plot(showBands ? 0.0 : na, "밴드경계4", color = color.new(color.gray, 100), editable = false)
fill(pB0, pB1, color = band3 ? colLow : colCur, title = "상단 밴드 (2단=현재TF · 3단=하위TF)")
fill(pB1, pB2, color = band3 ? colCur : na,     title = "중간 밴드 (3단=현재TF)")
fill(pB2, pB3, color = colHigh,                 title = "하단 밴드 (상위TF)")
tfName(string tf) => tf == "5" ? "5m" : tf == "15" ? "15m" : tf == "60" ? "1h" : tf == "240" ? "4h" : tf == "720" ? "12h" : tf == "D" ? "1D" : tf
var label lbBands = na
if showBands and barstate.islast
    label.delete(lbBands)
    string lowTxt = hasLow ? tfName(tfLow) : "—"
    string bandTxt = band3 ? "▲ " + lowTxt + "\n■ " + tfName(timeframe.period) + "\n▼ " + tfName(tfHigh) : "■ " + tfName(timeframe.period) + "\n▼ " + tfName(tfHigh)
    lbBands := label.new(bar_index + 1, 0.5, bandTxt, style = label.style_label_left, color = color.new(#131722, 30), textcolor = color.new(#c8c8c8, 0), size = size.small, tooltip = L("위 반은 현재 타임프레임, 아래 반은 한 단계 위 타임프레임의 상태입니다. 색이 진할수록 그 시점의 확신이 높습니다. 각 확신선이 자기 최근 30일 하위 20% 밑으로 2봉 연속 내려가면 X가 찍힙니다 — 그 뒤에는 상태가 바뀔 확률이 높아지므로 경계 신호로 읽어주세요. (상위 타임프레임은 간이 판정입니다)", "Bands: ■=current TF (top half, conf line+X) · ▼=one TF up (bottom half) · darker = higher confidence (HTF is 2-axis approx, no FSM) · X = confidence-collapse onset"))

// 확신선 — 밴드 위에 겹쳐 표시 (선 색 = 그 TF 레짐, 확정값: 리페인트 없음)
// 2단 모드: 두 줄 분리 — 위 반(0.5~1.0)=현재 TF conf, 아래 반(0~0.5)=상위 TF conf(2축 근사)
bool twoLine = showBands and not band3
float confLine = twoLine ? 0.5 + confShow * 0.5 : confShow
float q20Line  = twoLine ? 0.5 + confQ20Show * 0.5 : confQ20Show
float htfLine  = twoLine and not na(cfHigh) ? cfHigh * 0.5 : na
plot(confLine, "confidence (현재 TF)", color = ready and cur >= 0 ? stCol : color.gray, linewidth = 2)
plot(q20Line, "conf rolling q20", color = color.new(color.gray, 40), style = plot.style_line)
plot(htfLine, "confidence (상위 TF·2축 근사)", color = f_stateCol(stHigh), linewidth = 1)
// 상위 TF 확신 급락 — 현재 TF와 동일 정의(자기 30일 하위 20% 미만 2봉 연속)
hQ20 = ta.percentile_nearest_rank(cfHigh[1], qWin, 20)
bool hClps = not na(cfHigh) and not na(cfHigh[1]) and not na(hQ20) and not na(hQ20[1]) and cfHigh < hQ20 and cfHigh[1] < hQ20[1]
// X = 확신급락 '온셋'(첫 봉만 — 지속 구간 X 홍수 방지). 위 X=현재 TF · 아래 X=상위 TF
float clpsY  = collapse and not collapse[1] ? (twoLine ? 0.97 : 0.03) : na
float hClpsY = twoLine and hClps and not hClps[1] ? 0.03 : na
plotshape(clpsY, "confidence collapse (현재 TF)", style = shape.xcross, location = location.absolute, color = color.new(color.red, 0), size = size.tiny)
plotshape(hClpsY, "confidence collapse (상위 TF)", style = shape.xcross, location = location.absolute, color = color.new(color.red, 0), size = size.tiny)

// ── 상태 테이블 (메인 차트, 배경 있는 가독 버전) ────────────────────────────
posOf(string s) =>
    s == "좌상단" ? position.top_left : s == "중앙상단" ? position.top_center : s == "우상단" ? position.top_right : s == "좌중앙" ? position.middle_left : s == "중앙" ? position.middle_center : s == "우중앙" ? position.middle_right : s == "좌하단" ? position.bottom_left : s == "중앙하단" ? position.bottom_center : position.bottom_right
txtSz = tblSize == "아주작게" ? size.tiny : tblSize == "작게" ? size.small : tblSize == "크게" ? size.large : size.normal
color BG  = color.new(#131722, 10)
color BG2 = color.new(#1e222d, 10)
color TXT = color.new(#e8e8e8, 0)

// 셀 안에서 \n으로 2줄 이내 수동 줄바꿈 — 테이블 폭이 가장 긴 줄에 맞춰 늘어나기 때문
doTxt(i) => i == 0 ? L("이 상태의 기본 접근은 눌림목 롱입니다\n상위 타임프레임 방향을 먼저 확인하세요", "Pullback long (check HTF)") : i == 1 ? L("이 상태의 기본 접근은 되돌림 숏입니다\n상위 타임프레임 방향을 먼저 확인하세요", "Pullback short (check HTF)") : i == 2 ? L("돌파가 확인된 뒤에 진입하세요\n주요 레벨에 알림을 걸어두면 좋습니다", "Enter AFTER confirmed break") : i == 3 ? L("기본 접근은 박스 상·하단에서의 역매매입니다\n거래량을 확인하고 진입하세요", "Fade range edges (volume)") : L("관망하거나 포지션을 줄이는 것이 안전합니다", "Stand aside · size down")
dontTxt(i) => i == 0 ? L("추세를 거스르는 숏,\n그리고 물타기는 피하세요", "No counter-shorts · no averaging") : i == 1 ? L("추세를 거스르는 롱,\n떨어지는 칼날 잡기는 피하세요", "No counter-longs · no knife-catch") : i == 2 ? L("첫 돌파를 뒤쫓는 진입과\n방향을 미리 정해두는 베팅은 피하세요", "No chasing 1st break · no pre-bet") : i == 3 ? L("추세추종과 돌파 추격은 피하세요\n박스권은 돌파가 되돌아오기 쉬운 구간입니다", "No trend-following · no breakouts") : L("방향성 베팅 전부,\n특히 손실 복구용 복수 매매는 피하세요", "No directional bets · no revenge")
sName(i) => i == 0 ? L("상승", "up") : i == 1 ? L("하락", "down") : i == 2 ? L("수렴", "sqz") : i == 3 ? L("박스", "range") : i == 4 ? L("스퀴즈", "chop") : "?"

// 플레이북 충돌 오버라이드 (표시층 — 분류기 불변):
// 비추세 라벨 + (표류 태그 ON or 상위 TF 추세 문맥) → 레인지 페이드 문구 대체.
// 검증(continuation_study): HTF추세×LTF박스의 전방 share_up 0.485~0.527 — 어느 방향도
// 엣지 없음. 그래서 방향 조언은 넣지 않는다. 전달하는 건 하나: 박스 레벨 신뢰가 낮다.
// ADX≥25 팔(2·3단계 위)은 발화율 미캘리브 — 커버리지 우선 채택(편향은 '과다 경고' 쪽 = 보수적).
// current.py는 1h·4h 정본 라벨 TREND만 봄 — 표면 간 트리거 차이는 NOTES R7 매트릭스 참조.
bool htfTrendCtx = stH == 0 or stH == 1 or (not na(ax2) and ax2 >= 25) or (not na(ax3) and ax3 >= 25)
bool driftShow   = driftOn and driftTfOk and inPB
bool conflictPB  = inPB and (driftShow or htfTrendCtx)
bool oiOkShow    = barstate.isconfirmed ? oiOk : oiOk[1]

var table tb = table.new(posOf(posStr), 2, 9, border_width = 1, border_color = color.new(#000000, 60), force_overlay = true)
if barstate.islast
    table.clear(tb, 0, 0, 1, 8)
    // r0 지금 시장: 라벨 · n봉째 [· 표류±x.x%/24h] [· ≈2위]
    string dwellTxt = cur >= 0 ? " · " + str.tostring(sinceSwitch) + L("봉째", " bars") : ""
    string driftTag = driftShow and not na(driftVal) ? " · " + L("표류", "drift") + (driftVal > 0 ? "+" : "") + str.tostring(driftVal * 100, "0.0") + "%/24h" : ""
    string nearTag  = not na(rrShow) and rrShow >= 0.85 and rrIdxShow >= 0 and not watchOn ? " · ≈" + sName(rrIdxShow) : ""
    table.cell(tb, 0, 0, L("지금 시장", "Market now"), text_size = txtSz, bgcolor = BG, text_color = TXT)
    table.cell(tb, 1, 0, emojiOf(cur) + " " + nameOf(cur) + dwellTxt + driftTag + nearTag, text_color = color.white, bgcolor = cur >= 0 ? color.new(stCol, 20) : BG2, text_size = txtSz, tooltip = L("상태 색: 🟢상승추세 · 🔴하락추세 · 🔵수렴 · ⚪박스권 · 🟠스퀴즈. '표류'는 지난 24시간 동안 가격이 한쪽으로 2% 이상 밀렸다는 과거 사실 표시입니다 — 박스 경계를 믿고 역매매하기 어려운 상태라는 경고일 뿐, 그 방향으로 계속 간다는 뜻은 아닙니다. '≈'는 2위 상태와 점수가 거의 같다는 표시로, 과거 4년 기준 이 표시가 뜬 뒤 8봉 안에 상태가 바뀐 경우가 71%였습니다(평소에는 35%).", "Colors: up/down/squeeze/range/chop · drift = last-24h net move (descriptive only, no continuation edge — warns box levels unreliable) · ≈#2 = score ratio 85%+ (71% switch within 8 bars vs 35% base)"))
    // r1 판단 확신 (확정봉 백분위 등급 — 절대값은 툴팁)
    string gradeTxt = na(confPctShow) ? L("계산 중…", "computing…") : (confPctShow >= 70 ? L("높음 ●●●", "High ●●●") : confPctShow >= 30 ? L("보통 ●●○", "Mid ●●○") : L("낮음 ●○○", "Low ●○○")) + " · " + L("상위 ", "top ") + str.tostring(100 - confPctShow, "#") + "% (30" + L("일", "d") + ")"
    table.cell(tb, 0, 1, L("판단 확신", "Confidence"), text_size = txtSz, bgcolor = BG, text_color = TXT)
    table.cell(tb, 1, 1, gradeTxt, text_size = txtSz, bgcolor = BG2, text_color = TXT, tooltip = L("지금 확신 점수는 ", "Confirmed-bar confidence ") + str.tostring(confShow, "0.00") + L("입니다. 최근 30일 동안의 자기 자신과 비교했을 때의 상대적인 수준으로 등급을 매깁니다. 완성된 봉의 값만 사용하므로 봉 진행 중에 바뀌거나 새로고침 후 달라지지 않습니다.", " — graded vs its own last 30 days (confirmed bars only, no repaint)"))
    // r2 상위 TF: 한 단계 위 레짐(2축 근사) + 2·3단계 위 방향
    string htfCell = hName(tfHigh) + " " + emojiOf(stH) + sName(stH) + dirIcon(dp1, dm1, ax1) + " · " + hName(htf2) + " " + dirIcon(dp2, dm2, ax2) + " · " + hName(htf3) + " " + dirIcon(dp3, dm3, ax3)
    table.cell(tb, 0, 2, L("상위 TF", "Higher TFs"), text_size = txtSz, bgcolor = BG, text_color = TXT)
    table.cell(tb, 1, 2, htfCell, text_size = txtSz, bgcolor = BG2, text_color = TXT, tooltip = L("첫 항목은 한 단계 위 타임프레임의 시장 상태(간이 판정)이고, 뒤의 두 항목은 그보다 더 위 타임프레임들의 추세 방향입니다 (🟢 상승 · 🔴 하락 · ⚪ 뚜렷한 추세 없음). 방향과 레버리지 판단은 상위 타임프레임을 우선하는 것이 안전합니다.", "1st = one-TF-up regime (2-axis approx) + direction, rest = simple ADX25/DI (green up / red down / gray no-trend). Direction/leverage from HTF first"))
    // r3 진입 후보
    table.cell(tb, 0, 3, L("진입 후보", "Setup"), text_size = txtSz, bgcolor = BG, text_color = TXT)
    table.cell(tb, 1, 3, setupTxt, text_size = txtSz, bgcolor = setupTrig ? color.new(color.teal, 40) : BG2, text_color = TXT, tooltip = L("상위 타임프레임이 추세이고 현재 타임프레임이 횡보일 때 눌림목 진입 후보를 감지합니다. 다만 이 조건에 있다는 것만으로는 통계적인 우위가 없었습니다(4년 검증) — 진입 신호(DI 재가속)가 확정되고 손절 구조를 갖췄을 때만 의미가 있습니다. 기준 상위 타임프레임: ", "Habitat alone has NO edge (validated) — trigger & stop structure required. Ref HTF=") + hTfName + L(", 적정 추세 강도는 ADX 20~40입니다.", " sweet spot ADX 20-40"))
    // r4 전환 감시
    table.cell(tb, 0, 4, L("전환 감시", "Shift watch"), text_size = txtSz, bgcolor = BG, text_color = TXT)
    table.cell(tb, 1, 4, watchTxt, text_size = txtSz, bgcolor = watchOn or collapse ? color.new(color.red, 60) : BG2, text_color = TXT, tooltip = L("현재 상태의 점수가 2위 상태에 2봉 이상 계속 밀리고, 최근 8봉 안에 판단 확신 급감까지 겹칠 경우 경고가 표시됩니다. 이 두 조건이 함께 나타나면 실제로 상태가 바뀔 확률이 높습니다. 함께 표시되는 2위 상태는 예측이 아니라, 지금 점수가 두 번째로 높은 상태를 그대로 보여주는 것입니다.", "Strict: incumbent losing 2+ bars AND recent collapse. #2 is current score rank, not a forecast"))
    // r5 권장 / r6 금지 — 두 행 분리 (한 행에 몰면 셀이 옆으로 길어져 테이블 폭이 커짐)
    string pbDo   = conflictPB ? L("박스 상·하단 레벨을 믿기 어려운 구간입니다\n역매매는 보류하고, 진입 신호가 확정된 뒤\n평소보다 작은 사이즈로 접근하세요", "Box levels unreliable — hold fades,\nwait for trigger, size down") : cur >= 0 ? doTxt(cur) : "…"
    string pbDont = conflictPB ? L("움직이고 있는 박스 경계에서의\n역매매와 물타기는 위험합니다", "No fading moving box edges,\nno averaging") : cur >= 0 ? dontTxt(cur) : "…"
    string pbTip  = conflictPB ? L("상위 타임프레임이 추세이거나 가격이 24시간째 한쪽으로 밀리고 있을 경우, 박스권 역매매의 전제(고정된 상·하단)가 깨져 있을 확률이 높습니다. 다만 이런 구간에서도 어느 방향으로 갈지에 대한 통계적 우위는 없었습니다 — 방향 신호가 아니라 '레벨을 믿지 말라'는 경고로 읽어주세요.", "Conflict/drift: HTF trending or 24h drifting — NO directional edge either way (validated). Box-fade premise (stable levels) is broken; not a direction signal") : L("현재 상태에서 통계적으로 유리했던 기본 권고입니다. 방향과 레버리지 판단은 상위 타임프레임을 우선하세요.", "Default playbook per label — direction/leverage from HTF first")
    table.cell(tb, 0, 5, L("권장", "Do"), text_size = txtSz, bgcolor = BG, text_color = TXT)
    table.cell(tb, 1, 5, pbDo, text_size = txtSz, bgcolor = conflictPB ? color.new(color.orange, 72) : BG2, text_color = TXT, tooltip = pbTip)
    table.cell(tb, 0, 6, L("금지", "Avoid"), text_size = txtSz, bgcolor = BG, text_color = TXT)
    table.cell(tb, 1, 6, pbDont, text_size = txtSz, bgcolor = conflictPB ? color.new(color.orange, 72) : BG2, text_color = TXT, tooltip = pbTip)
    // r7 OI 사분면 (확정 스냅샷 — 항상 최하단)
    string quadTxt = not oiOkShow ? L("OI 데이터가 없거나 준비 중입니다", "no OI") : not fuelDefShow ? L("기준선 계산 중 (OI 이력 20일 미만)", "deadzone warming (<20d)") : quadShow == 1 ? "🟩 " + L("신규 롱 자금이 들어오는 중 — 추세 연료로 반영", "new longs — fuel (votes)") : quadShow == 2 ? "🟥 " + L("신규 숏 자금이 들어오는 중 — 추세 연료로 반영", "new shorts — fuel (votes)") : quadShow == 3 ? "↩ " + L("숏 커버(기존 숏 정리) 중\n판정은 그대로 두고 확신만 15% 낮춰 반영", "short covering — conf −15%") : quadShow == 4 ? "↩ " + L("롱 청산(기존 롱 정리) 중\n판정은 그대로 두고 확신만 15% 낮춰 반영", "long liquidation — conf −15%") : "— " + L("특별한 OI 변화가 없습니다", "deadzone (no meaningful ΔOI)")
    table.cell(tb, 0, 7, L("OI 사분면", "OI quadrant"), text_size = txtSz, bgcolor = BG, text_color = TXT)
    table.cell(tb, 1, 7, quadTxt, text_size = txtSz, bgcolor = BG2, text_color = quadShow == 1 ? color.new(color.green, 10) : quadShow == 2 ? color.new(color.red, 10) : TXT, tooltip = L("최근 2시간의 미결제약정(OI) 변화와 가격 변화를 함께 읽습니다. 둘 다 늘면 신규 롱, OI가 늘고 가격이 내리면 신규 숏 — 이 두 경우는 추세의 연료로 보고 판정에 반영합니다. 반대로 OI가 줄어드는 경우(숏 커버·롱 청산)는 무기한 선물에서 오히려 강한 연속 움직임이 나올 때가 많아, 판정은 바꾸지 않고 확신만 낮춥니다. 데이터: ", "ΔOI(2h)×Δprice(2h) sign table · data: ") + (oiFromPerp ? L("무기한 OI 폴백", "perp OI fallback") : "OI") + L(" · 펀딩 극단 보정은 트레이딩뷰에 펀딩 데이터가 없어 적용하지 못했습니다", " · funding trim not ported (no TV feed)"))
    // r8 데이터 (조건부 — 비정상일 때만 표시)
    if not fuelDefShow
        table.cell(tb, 0, 8, L("데이터", "Data"), text_size = txtSz, bgcolor = BG, text_color = TXT)
        table.cell(tb, 1, 8, L("OI 데이터가 준비 중이거나 끊겼습니다\n확신을 20% 낮춘 보수적 판정으로 동작 중", "OI warming/missing → conservative (conf ×0.8)"), text_size = txtSz, bgcolor = color.new(color.maroon, 55), text_color = TXT)

alertcondition(ta.change(cur) != 0, "Regime change", "REGIME v1: 시장 상태가 바뀌었습니다 / regime changed")
alertcondition(collapse and not collapse[1], "Confidence collapse", "REGIME v1: 판단 확신이 급감했습니다 — 상태가 바뀔 가능성이 있습니다 / confidence collapse onset")
alertcondition(setupTrig, "Pullback trigger", "REGIME v1: 눌림목 진입 신호 — DI 재가속이 확인됐습니다 / pullback trigger")
alertcondition(driftShow and not driftShow[1], "Drift onset", "REGIME v1: 표류가 시작됐습니다 — 박스 레벨을 믿기 어려운 구간입니다 (방향 신호 아님) / drift onset")   // 테이블 태그와 동일 게이트(비추세 라벨+검증 TF)
