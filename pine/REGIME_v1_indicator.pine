//@version=6
// REGIME v1 — 5-상태 레짐 분류기 (research/regime 파이썬 구현의 차트 포팅)
//
// 산출물 계약: 캔들마다 {레짐, confidence} 만. 예측·목표가·시그널 없음.
// 5상태: TREND_UP / TREND_DOWN / SQUEEZE(저변동 수렴) / RANGE(중변동) / CHOP(고변동 무질서)
//
// 파라미터는 파이썬 리서치에서 동결된 값 그대로 (재튜닝 금지 — 포킹패스 규율).
// 검증된 사실(BTCUSDT 15m, 2022→2026 + ETH/SOL/XRP 무튜닝 복제, 리서치 하네스):
//   - 이 분류기는 원시 ADX(25) 대비 진입이 중앙값 4~6캔들 늦은 대신 churn −33%(3.25 vs
//     4.83 flips/100봉)·오경보 ~0.07/100봉 — "늦지만 깨끗한" 레짐 게이트.
//   - 정직성 고지: OI 융합의 +1캔들 조기화는 순환 시간이동 널과 구별 불가(p=1.0) —
//     OI *정렬 정보*의 타이밍 알파는 검출되지 않음. 연료 축은 구조 효과(Δprice 레그)로
//     동작하며, ΔOI 하강 사분면(숏커버·롱청산)은 라벨 불변·confidence만 삭감.
//   - confirm_bars=1 로 올리면 리드 희생 0에 churn 추가 −26% (스윕 표 참조).
//
// OI 피드: TradingView는 "<프리픽스>:<티커>_OI" 심볼로 OI를 제공 (분 단위, Binance 무기한
// 커버). 피드가 없으면(ignore_invalid_symbol) 연료 축을 끄고 confidence x0.8 — degrade 경로.
indicator("REGIME v1 — 5-state regime [Gunner]", overlay = false, max_bars_back = 5000)

// ── 동결 파라미터 ────────────────────────────────────────────────────────────
adxLen   = input.int(14,  "ADX/DI 기간",       group = "동결 파라미터(리서치)")
adxLo    = input.float(20, "ADX 하한",          group = "동결 파라미터(리서치)")
adxScale = input.float(15, "ADX 스케일",        group = "동결 파라미터(리서치)")
emaFLen  = input.int(20,  "EMA fast",           group = "동결 파라미터(리서치)")
emaSLen  = input.int(50,  "EMA slow",           group = "동결 파라미터(리서치)")
bbLen    = input.int(20,  "BB 기간",            group = "동결 파라미터(리서치)")
bbK      = input.float(2.0, "BB 표준편차",      group = "동결 파라미터(리서치)")
qWin     = input.int(2880, "분위수 창(봉)",     group = "동결 파라미터(리서치)", tooltip = "15m에서 30일. 차트 히스토리가 짧으면 자동 축소")
kOI      = input.int(8,   "ΔOI lookback(봉)",   group = "동결 파라미터(리서치)")
deadQ    = input.int(25,  "데드존 분위(%)",     group = "동결 파라미터(리서치)")
wDir     = 0.5
wVol     = 0.3
wFuel    = 0.2
nearTie  = 0.02
// hysteresis — 기본 OFF (리서치와 동일)
minDwell    = input.int(0, "min_dwell(봉)",     group = "hysteresis (기본 OFF)")
confirmBars = input.int(0, "confirm_bars(봉)",  group = "hysteresis (기본 OFF)")

// ── 피처 (전부 인과: 현재 봉 종가까지만) ────────────────────────────────────
[diP, diM, adx] = ta.dmi(adxLen, adxLen)
atr  = ta.rma(ta.tr(true), adxLen)
m    = (ta.ema(close, emaFLen) - ta.ema(close, emaSLen)) / atr
bbw  = 2 * bbK * ta.stdev(close, bbLen) / ta.sma(close, bbLen)
atrp = atr / close
// 창 길이는 simple int 고정(2880=15m 30일). 히스토리 부족 시 na → 리서치의 번인과 동일 의미
volPct = (ta.percentrank(bbw, qWin) + ta.percentrank(atrp, qWin)) / 200.0  // 과거 전용

// OI (없으면 na → degrade)
string oiSym = syminfo.prefix + ":" + syminfo.ticker + "_OI"
oiClose = request.security(oiSym, timeframe.period, close, ignore_invalid_symbol = true)
oiOk    = not na(oiClose) and not na(oiClose[kOI])
doi     = oiOk ? (oiClose - oiClose[kOI]) / oiClose[kOI] : na
dpr     = (close - close[kOI]) / close[kOI]
dzDoi   = ta.percentile_nearest_rank(math.abs(doi[1]), qWin, deadQ)   // 과거 전용(1봉 시프트)
dzDpr   = ta.percentile_nearest_rank(math.abs(dpr[1]), qWin, deadQ)
// 사분면: 0=연료없음/데드존, 1=신규롱, 2=신규숏, 3=숏커버, 4=롱청산
quadOn = oiOk and not na(dzDoi) and not na(dzDpr) and math.abs(doi) >= dzDoi and math.abs(dpr) >= dzDpr
quad   = not quadOn ? 0 : doi > 0 and dpr > 0 ? 1 : doi > 0 and dpr < 0 ? 2 : doi < 0 and dpr > 0 ? 3 : doi < 0 and dpr < 0 ? 4 : 0

// ── 축 점수 → 5상태 ─────────────────────────────────────────────────────────
a      = math.max(0.0, math.min(1.0, (adx - adxLo) / adxScale))
tRaw   = a * math.tanh(math.abs(m))
agreeD = math.sign(diP - diM) == math.sign(m)
T      = agreeD ? tRaw : tRaw * 0.5
dirUp   = m > 0 ? T : 0.0
dirDn   = m < 0 ? T : 0.0
dirRest = (1.0 - dirUp - dirDn) / 3.0
muL = math.max(0.0, math.min(1.0, (0.25 - volPct) / 0.10))
muH = math.max(0.0, math.min(1.0, (volPct - 0.75) / 0.10))
muM = math.max(0.0, 1.0 - muL - muH)

fuelVotes = quad == 1 or quad == 2
wPresent  = wDir + wVol + (fuelVotes ? wFuel : 0.0)
sUP = (wDir * dirUp   + (quad == 1 ? wFuel : 0.0)) / wPresent
sDN = (wDir * dirDn   + (quad == 2 ? wFuel : 0.0)) / wPresent
sSQ = (wDir * dirRest + wVol * muL) / wPresent
sRA = (wDir * dirRest + wVol * muM) / wPresent
sCH = (wDir * dirRest + wVol * muH) / wPresent

// argmax + 니어타이 현직 우선 + 온라인 FSM(확정 봉 스탬프, 역서명 없음)
var int cur = -1
var int pending = -1
var int pendCnt = 0
var int sinceSwitch = 100000
score(i) => i == 0 ? sUP : i == 1 ? sDN : i == 2 ? sSQ : i == 3 ? sRA : sCH
int best = 0
float bestV = sUP
if sDN > bestV
    best := 1
    bestV := sDN
if sSQ > bestV
    best := 2
    bestV := sSQ
if sRA > bestV
    best := 3
    bestV := sRA
if sCH > bestV
    best := 4
    bestV := sCH
bool ready = not na(volPct) and not na(m) and not na(adx)
if ready
    int cand = cur >= 0 and score(cur) >= bestV - nearTie ? cur : best
    if cur < 0
        cur := cand
        sinceSwitch := 0
    else if cand != cur
        pendCnt := cand == pending ? pendCnt + 1 : 1
        pending := cand
        if pendCnt >= confirmBars + 1 and sinceSwitch >= minDwell
            cur := cand
            sinceSwitch := 0
            pending := -1
            pendCnt := 0
    else
        pending := -1
        pendCnt := 0
    sinceSwitch += 1

// confidence = 합의 × 마진, 연료/degrade 수정자, [0,1] 클램프 (펀딩 수정자는 TV 피드 부재로 제외)
float agreement = ready and cur >= 0 ? score(cur) : na
float runnerUp = 0.0
if ready and cur >= 0
    for i = 0 to 4
        if i != cur and score(i) > runnerUp
            runnerUp := score(i)
float fuelMod = quad == 3 or quad == 4 ? 0.85 : oiOk and quad == 0 ? 0.95 : 1.0
float conf = na(agreement) ? na : math.max(0.0, math.min(1.0, agreement * (1.0 - 0.5 * (agreement > 1e-12 ? runnerUp / agreement : 2.0)) * fuelMod * (oiOk ? 1.0 : 0.8)))

// ── 표시 ────────────────────────────────────────────────────────────────────
color stCol = cur == 0 ? color.green : cur == 1 ? color.red : cur == 2 ? color.purple : cur == 3 ? color.gray : color.orange
string stName = cur == 0 ? "TREND_UP" : cur == 1 ? "TREND_DOWN" : cur == 2 ? "SQUEEZE" : cur == 3 ? "RANGE" : cur == 4 ? "CHOP" : "…"
int transp = na(conf) ? 90 : int(90 - 70 * math.min(conf / 0.6, 1.0))
bgcolor(ready ? color.new(stCol, transp) : na, title = "regime ribbon", force_overlay = true)
plot(conf, "confidence", color = color.new(color.blue, 0), linewidth = 1)
confQ20 = ta.percentile_nearest_rank(conf[1], qWin, 20)
plot(confQ20, "conf rolling q20", color = color.new(color.gray, 40), style = plot.style_line)
collapse = not na(conf) and not na(conf[1]) and not na(confQ20) and not na(confQ20[1]) and conf < confQ20 and conf[1] < confQ20[1]
plotshape(collapse, "confidence collapse", style = shape.xcross, location = location.bottom, color = color.new(color.red, 0), size = size.tiny)

var table tb = table.new(position.top_right, 2, 5, border_width = 1)
if barstate.islast
    pb1 = cur == 0 ? "추세추종 롱(눌림목)" : cur == 1 ? "추세추종 숏(되돌림)" : cur == 2 ? "돌파 대기" : cur == 3 ? "레인지 평균회귀" : "관망/리스크오프"
    av1 = cur == 0 or cur == 1 ? "역추세 페이드 금지" : cur == 2 ? "추세진입 금지" : cur == 3 ? "추세추종·돌파추격 금지" : "방향성 전부 금지"
    table.cell(tb, 0, 0, "REGIME", text_color = color.white, bgcolor = stCol)
    table.cell(tb, 1, 0, stName, text_color = color.white, bgcolor = stCol)
    table.cell(tb, 0, 1, "confidence")
    table.cell(tb, 1, 1, na(conf) ? "…" : str.tostring(conf, "0.000"))
    table.cell(tb, 0, 2, "OI 연료축")
    table.cell(tb, 1, 2, oiOk ? "ON (" + oiSym + ")" : "OFF → degrade x0.8")
    table.cell(tb, 0, 3, "주력")
    table.cell(tb, 1, 3, pb1)
    table.cell(tb, 0, 4, "금지")
    table.cell(tb, 1, 4, av1)

alertcondition(ta.change(cur) != 0, "Regime change", "REGIME v1: 레짐 전환")
alertcondition(collapse, "Confidence collapse", "REGIME v1: confidence 붕괴 — 전환 가능성")
