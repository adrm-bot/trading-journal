# journal/.env  ← .env 로 복사해 채움. .env 는 git 미추적(.gitignore).
# 모든 거래소 키는 read-only 전용. 주문/출금 권한 금지.

# --- 거래소 (멀티거래소 — 콤마로 여러개) ---
EXCHANGES=bybit
LOOKBACK_DAYS=7

# Bybit (read-only)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Binance USDⓈ-M 선물 (read-only) — EXCHANGES 에 binance 추가 시
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- 저장처 ---
JOURNAL_BACKEND=excel        # excel(로컬, 인증0) | notion(개인 계정)

# --- Notion (JOURNAL_BACKEND=notion 일 때) ---
# 1) 네 계정에서 notion.so/my-integrations → internal integration → secret = NOTION_TOKEN
# 2) 네 Notion에 페이지 하나 만들고 그 페이지 ⋯ → Connections → 위 integration 연결
#    → 그 페이지 id = NOTION_PARENT_PAGE_ID
# 3) python setup_notion.py 실행 → 나온 database id 를 NOTION_DB_ID 에
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=
NOTION_DB_ID=

# --- Telegram 알림 (폰 푸시) ---
# @BotFather → /newbot → 토큰 / 봇에게 메시지 후 api.telegram.org/bot<토큰>/getUpdates 로 chat id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
